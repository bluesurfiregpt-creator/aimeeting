/* app.wxss — 全局样式 + 4 个主 tab 页共享的 layout / header / segment / navbar.
 *
 * v1.4.0 Saga F · 浅色化重写: 跟 Mobile MR_COLORS 1:1 (frontend/src/components/mobile/meeting-room/styles.ts).
 * NORTH_STAR § 7.1 不做 dark mode — 全栈走 iOS 浅色.
 *
 * 设计原则 — 跟 H5 (frontend/src/app/m + components/mobile/meeting-room) 对齐:
 *   - page bg = #F2F2F7 (iOS systemGroupedBackground)
 *   - card / surface = #FFFFFF
 *   - 文字 primary #1C1C1E / secondary #3C3C43 / tertiary #8E8E93
 *   - hairline rgba(60,60,67,0.12) / separator #E5E5EA
 *   - 系统色 blue #007AFF / green #34C759 / red #FF3B30 / orange #FF9F0A / purple #5E5CE6
 *   - 字号 / 留白 跟 frontend/src/components/mobile/{PageHeader, SegmentControl, BottomNav} 对应
 */

page {
  background-color: #F2F2F7;
  color: #1C1C1E;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
}

/* v27.2 关键 reset: mini program 默认 box-sizing 是 content-box,
 * 跟 web 现代标准 (border-box) 不一致 — 元素 padding 会"加"在 width 之外,
 * 让 容器 + 内部 padding 叠起来 撑破 容器 → 用户截图里"右侧 dashed border
 * 被屏幕切掉" 就是 这个 原因. 全局 reset 后所有 view/scroll-view/button 都用
 * border-box, padding 计入 width 内, 不再 overflow. */
view, scroll-view, button, input, image, text, swiper, swiper-item, navigator {
  box-sizing: border-box;
}

/* 防御性: 任 一 page 根容器 强 width: 100% + overflow-x: hidden, 万一
 * 某子元素 设了 width 超大, 不会 水平滚出来. */
.page {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

/* ============ 通用 layout (4 主 tab 共享) ============ */
.tab-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: #F2F2F7;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
.tab-hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.tab-hd-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1;
  letter-spacing: -0.5rpx;
}

/* ============ Segment Control (跟 H5 SegmentControl 对齐) ============ */
/* iOS 浅: 容器底色 #E5E5EA, active 段 #FFFFFF 抬起 (跟 iOS 系统 segment 一致). */
.tab-segment {
  margin-top: 32rpx;
  display: flex;
  background: #E5E5EA;
  border-radius: 24rpx;
  padding: 8rpx;
}
.tab-seg-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: #3C3C43;
  border-radius: 16rpx;
  transition: background 0.2s ease, color 0.2s ease;
}
.tab-seg-count {
  font-size: 26rpx;
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}
.tab-seg-on {
  background: #FFFFFF;
  color: #1C1C1E;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}
.tab-seg-on .tab-seg-count {
  color: #3C3C43;
}
.tab-seg-count-warn {
  color: #B8860B;
}

/* ============ Body (scroll) ============ */
.tab-body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 0;
}

/* ============ Bottom Nav (跟 H5 BottomNav 对齐) ============ */
/* iOS 浅: bg 跟 page 一致 #F2F2F7, 无 border-top, active 用 iOS blue. */
.tab-navbar {
  flex-shrink: 0;
  display: flex;
  background: #F2F2F7;
}
.tab-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 8rpx;
  height: 96rpx;
  color: #8E8E93;
  transition: color 0.2s ease;
}
.tab-nav-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.tab-nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tab-nav-on {
  color: #007AFF;
}
.tab-nav-on .tab-nav-emoji {
  opacity: 1;
}

/* ============ 通用入场 ============ */
@keyframes page-fade-anim {
  from { opacity: 0; }
  to { opacity: 1; }
}
.page-fade-in {
  animation: page-fade-anim 0.18s ease-out both;
}

@keyframes slide-up-anim {
  from { opacity: 0; transform: translateY(20rpx) scale(0.985); }
  to   { opacity: 1; transform: translateY(0)     scale(1); }
}
.slide-up-in {
  animation: slide-up-anim 0.32s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes fade-scale-anim {
  from { opacity: 0; transform: scale(0.95); }
  to   { opacity: 1; transform: scale(1); }
}
.fade-scale-in {
  animation: fade-scale-anim 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

/* ============ 通用 tap 反馈 ============ */
.tap-scale {
  transform: scale(0.97);
  transition: transform 0.12s ease;
}
.tap-highlight {
  background: rgba(60, 60, 67, 0.06);
}

/* ============ 自定义导航栏 — 子页 (带返回按钮) ============ */
/* navigationStyle: custom 后 WeChat 不画标题栏, 子页 (我的 / 通知) 自己画
 * 一条 带 返回 ‹ + 居中标题 的 nav bar. statusBarHeight / navBarHeight 由
 * utils/nav.js getNavMetrics() 算, 页面 inline style 注入. */
.cnav {
  flex-shrink: 0;
  background: #F2F2F7;
}
.cnav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cnav-back {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cnav-back-arrow {
  font-size: 52rpx;
  color: #007AFF;
  line-height: 1;
  font-weight: 300;
}
.cnav-back-hover {
  opacity: 0.5;
}
.cnav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ Header 右上 icon button (跟 H5 PageHeader 对齐) ============ */
/* H5 浅: 40x40 圆按钮, 默认灰, active bg #E5E5EA + 字 #1C1C1E */
.hd-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.hd-icons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.hd-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #8E8E93;
  transition: background 0.15s ease, color 0.15s ease;
}
.hd-icon-hover {
  background: #E5E5EA;
  color: #1C1C1E;
}
