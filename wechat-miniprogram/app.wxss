/* app.wxss — 全局样式 + 4 个主 tab 页共享的 layout / header / segment / navbar.
 *
 * v27.2 重写: 4 主 tab (home / meetings_list / tasks_list / insights) UI 一致,
 * 把 公共骨架 抽过来. 各 page wxss 只放 自己 独有的 卡片样式.
 *
 * 设计原则 — 跟 H5 对齐:
 *   - 字号 / 留白 / 配色 跟 frontend/src/components/mobile/{PageHeader, SegmentControl, BottomNav} 对应
 *   - 取消 navbar 上 1px 浅边 (用户反馈"白色缝隙") — navbar 直接 bg 跟页面 bg 一致, 没分割线
 *   - segment 用 半透明 + 浅 active (zinc-700) — iOS pill 风
 *   - bg color 全 走 ink-950 (#0a0a0c) → ink-900 (#18181b) → zinc-700 (#3f3f46) 三层
 */

page {
  background-color: #0a0a0c;
  color: #fafafa;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* v27.2 关键 reset: mini program 默认 box-sizing 是 content-box,
 * 跟 web 现代标准 (border-box) 不一致 — 元素 padding 会"加"在 width 之外,
 * 让 容器 + 内部 padding 叠起来 撑破 容器 → 用户截图里"右侧 dashed border
 * 被屏幕切掉" 就是 这个 原因. 全局 reset 后所有 view/scroll-view/button 都用
 * border-box, padding 计入 width 内, 不再 overflow. */
view, scroll-view, button, input, image, text, swiper, swiper-item, navigator {
  box-sizing: border-box;
}

/* 防御性: 任 一 page 根容器 强 width: 100% + overflow-x: hidden, 万一
 * 某子元素 设了 width 超大, 不会 水平滚出来. */
.page {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

/* ============ 通用 layout (4 主 tab 共享) ============ */
.tab-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: #0a0a0c;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
/* H5: px-4 pt-5 pb-3 + 大标题 26px font-semibold leading-none zinc-50 */
.tab-hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.tab-hd-title {
  font-size: 52rpx;  /* H5 text-[26px] */
  font-weight: 600;
  color: #fafafa;
  line-height: 1;
  letter-spacing: -0.5rpx;
}

/* ============ Segment Control (跟 H5 SegmentControl 对齐) ============ */
/* H5: inline-flex w-full rounded-xl bg-ink-900/60 p-1, h-10 buttons text-[15px], active bg-zinc-700 */
.tab-segment {
  margin-top: 32rpx;
  display: flex;
  background: rgba(24, 24, 27, 0.6);   /* ink-900/60 */
  border-radius: 24rpx;                /* rounded-xl ~12px */
  padding: 8rpx;                       /* p-1 */
}
.tab-seg-item {
  flex: 1;
  height: 80rpx;                       /* h-10 */
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;                          /* gap-1.5 */
  font-size: 30rpx;                    /* text-[15px] */
  color: #d4d4d8;                      /* zinc-300 */
  border-radius: 16rpx;                /* rounded-lg */
  transition: background 0.2s ease, color 0.2s ease;
}
.tab-seg-count {
  font-size: 26rpx;                    /* text-[13px] */
  color: #71717a;                      /* zinc-500 */
  font-variant-numeric: tabular-nums;
}
.tab-seg-on {
  background: #3f3f46;                 /* zinc-700 */
  color: #fafafa;                      /* zinc-50 */
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}
.tab-seg-on .tab-seg-count {
  color: #d4d4d8;                      /* zinc-300 active 时 数字也跟着亮 */
}
.tab-seg-count-warn {
  color: #fcd34d;                      /* amber-300 — 待审 tab 用 */
}

/* ============ Body (scroll) ============ */
.tab-body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 0;
}

/* ============ Bottom Nav (跟 H5 BottomNav 对齐) ============ */
/* H5: fixed bottom-0 border-t border-ink-800 bg-ink-950/95 backdrop-blur, h-14 buttons,
   text-xl emoji + text-[11px] label, active text-accent-300.
   注: 这里 不用 fixed (mini program 用 flex column 更稳, scroll 不抖). 但 bg 跟 page 一样,
   去掉 border-top, 消除 "白色缝隙" 感觉. */
.tab-navbar {
  flex-shrink: 0;
  display: flex;
  background: #0a0a0c;                 /* 跟 page bg 完全 一样 — 不产生 视觉断层 */
  /* 没有 border-top — 这是 用户 反馈 的 "白色缝隙" 的 元凶 */
}
.tab-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 8rpx;
  height: 96rpx;                       /* H5 h-14 = 56px = 112rpx, 留点紧凑 */
  color: #71717a;                      /* zinc-500 */
  transition: color 0.2s ease;
}
.tab-nav-emoji {
  font-size: 40rpx;                    /* H5 text-xl = 20px = 40rpx */
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.tab-nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;                    /* H5 text-[11px] */
  font-weight: 500;
}
.tab-nav-on {
  color: #c4b5fd;                      /* H5 text-accent-300 */
}
.tab-nav-on .tab-nav-emoji {
  opacity: 1;
}

/* ============ 通用入场 ============ */
@keyframes page-fade-anim {
  from { opacity: 0; }
  to { opacity: 1; }
}
.page-fade-in {
  animation: page-fade-anim 0.18s ease-out both;
}

@keyframes slide-up-anim {
  from { opacity: 0; transform: translateY(20rpx) scale(0.985); }
  to   { opacity: 1; transform: translateY(0)     scale(1); }
}
.slide-up-in {
  animation: slide-up-anim 0.32s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes fade-scale-anim {
  from { opacity: 0; transform: scale(0.95); }
  to   { opacity: 1; transform: scale(1); }
}
.fade-scale-in {
  animation: fade-scale-anim 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

/* ============ 通用 tap 反馈 ============ */
.tap-scale {
  transform: scale(0.97);
  transition: transform 0.12s ease;
}
.tap-highlight {
  background: rgba(255, 255, 255, 0.04);
}

/* ============ 自定义导航栏 — 子页 (带返回按钮) ============ */
/* navigationStyle: custom 后 WeChat 不画标题栏, 子页 (我的 / 通知) 自己画
 * 一条 带 返回 ‹ + 居中标题 的 nav bar. statusBarHeight / navBarHeight 由
 * utils/nav.js getNavMetrics() 算, 页面 inline style 注入. */
.cnav {
  flex-shrink: 0;
  background: #0a0a0c;
}
.cnav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cnav-back {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cnav-back-arrow {
  font-size: 52rpx;
  color: #fafafa;
  line-height: 1;
  font-weight: 300;
}
.cnav-back-hover {
  opacity: 0.5;
}
.cnav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fafafa;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ Header 右上 icon button (跟 H5 PageHeader 对齐) ============ */
/* H5: 40x40 圆按钮, 默认灰, active bg-ink-800 + 字 zinc-200 */
.hd-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.hd-icons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.hd-icon-btn {
  width: 72rpx;                    /* H5 h-10 w-10 = 80rpx, 微缩 */
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #a1a1aa;                  /* zinc-400 */
  transition: background 0.15s ease, color 0.15s ease;
}
.hd-icon-hover {
  background: #27272a;             /* zinc-800 */
  color: #e4e4e7;                  /* zinc-200 */
}
