/* custom-tab-bar/index.wxss — v1.4.0 Saga F 自定义 tabBar (iOS 浅色)
   配色对齐 MR_COLORS: bg 跟 page #F2F2F7 一致, active iOS blue */

.tabbar {
  display: flex;
  background: #F2F2F7;
  padding-top: 6rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  color: #8E8E93;
  transition: color 0.18s ease;
}

.tab-hover {
  opacity: 0.7;
}

.tab-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.18s ease, transform 0.18s ease;
}

.tab-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tab-on {
  color: #007AFF;
}
.tab-on .tab-emoji {
  opacity: 1;
  transform: scale(1.08);
}
