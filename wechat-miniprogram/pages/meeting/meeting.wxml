<!-- pages/meeting/meeting.wxml — N-1 第 1 刀: 骨架 -->
<view class="container">

  <!-- Loading -->
  <view wx:if="{{loading}}" class="state-block">
    <view class="state-emoji">⏳</view>
    <view class="state-text">加载中…</view>
  </view>

  <!-- 没 token 时引导 + 开发模式 fallback -->
  <view wx:elif="{{needToken}}" class="state-block">
    <view class="state-emoji">📱</view>
    <view class="state-title">请从会议详情页进入</view>
    <view class="state-body">
      正确进入方式: 回小程序首页 → 点击会议 → 进入 H5 详情页 →
      点紫色 "试用原生会议室 进入 →" 按钮.
      原生页通过 这条路径 拿登录态, 不能直接打开.
    </view>
    <button class="btn-primary" bindtap="onBack">回会议页</button>

    <!-- 开发模式 fallback — 仅给开发者用, 真机用户用上面的按钮 -->
    <view class="dev-fallback-divider">— 或开发模式 —</view>
    <textarea
      class="dev-input"
      placeholder="粘贴 token (eyJhb...)"
      value="{{devTokenInput}}"
      bindinput="onDevTokenInput"
      auto-height
    />
    <input
      class="dev-input-line"
      placeholder="(可选) expires_at ISO"
      value="{{devTokenExpInput}}"
      bindinput="onDevTokenExpInput"
    />
    <button class="btn-secondary" bindtap="onDevTokenConfirm">用 token 登录</button>
    <view wx:if="{{error}}" class="state-error">{{error}}</view>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{error}}" class="state-block">
    <view class="state-emoji">⚠️</view>
    <view class="state-text">{{error}}</view>
    <button class="btn-secondary" bindtap="onRefresh">重试</button>
    <button class="btn-text" bindtap="onBack">返回</button>
  </view>

  <!-- 主内容 -->
  <view wx:elif="{{detail}}" class="meeting-body">

    <!-- 状态横条 -->
    <view class="status-bar status-{{detail.status}}">
      <text wx:if="{{detail.status === 'ongoing'}}">● 进行中 · 已 {{detail.started_minutes_ago}} 分钟</text>
      <text wx:elif="{{detail.status === 'scheduled'}}">○ 未开始</text>
      <text wx:elif="{{detail.status === 'finished'}}">✓ 已结束</text>
      <text wx:elif="{{detail.status === 'processed'}}">✓ 已沉淀</text>
      <text wx:else>{{detail.status}}</text>
    </view>

    <!-- 议程 banner -->
    <view wx:if="{{banner}}" class="banner banner-{{banner.tone}}">
      <view class="banner-emoji">{{banner.emoji}}</view>
      <view class="banner-body">
        <view class="banner-title">
          {{banner.title}}
          <text wx:if="{{banner.countdownSec > 0}}" class="banner-countdown">{{banner.countdownSec}}s</text>
        </view>
        <view class="banner-text">{{banner.text}}</view>
        <view wx:if="{{banner.sub}}" class="banner-sub">{{banner.sub}}</view>
        <!-- 第 5 刀: autoSummon 时显 "立刻召唤" 按钮 -->
        <view wx:if="{{banner.autoSummon}}" class="banner-actions">
          <button class="btn-banner-summon" bindtap="onBannerSummonNow">立刻召唤主持人</button>
        </view>
      </view>
      <view class="banner-close" bindtap="onBannerClose">×</view>
    </view>

    <!-- 议程 chip 行 (横滑) -->
    <scroll-view wx:if="{{agendaChips.length > 0}}" scroll-x class="agenda-row">
      <view
        wx:for="{{agendaChips}}"
        wx:key="idx"
        class="agenda-chip {{item.toneClass}} {{item.isCurrent ? 'chip-highlight' : ''}}"
      >
        <view class="chip-icon">{{item.statusIcon}}</view>
        <view class="chip-title">{{item.title}}</view>
        <view wx:if="{{item.timeBudget}}" class="chip-meta">
          <text wx:if="{{item.elapsedMin !== null}}">{{item.elapsedMin}}/</text>{{item.timeBudget}}m
        </view>
      </view>
    </scroll-view>

    <!-- 当前议题 + Insights (第 1 刀只显文本占位; 第 4 刀做完整 AI 气泡) -->
    <view wx:if="{{detail.current_topic_title}}" class="current-topic">
      <view class="topic-label">当前议题</view>
      <view class="topic-title">{{detail.current_topic_title}}</view>
      <view wx:if="{{detail.current_topic_elapsed_min}}" class="topic-meta">
        已议 {{detail.current_topic_elapsed_min}} 分钟
      </view>
      <view wx:if="{{detail.current_topic_insights && detail.current_topic_insights.length > 0}}" class="insights-mini">
        <text class="insights-label">本议题 AI 快照 · {{detail.current_topic_insights.length}}</text>
        <view
          wx:for="{{detail.current_topic_insights}}"
          wx:for-item="ins"
          wx:key="id"
          class="insight-mini"
        >
          <text class="insight-type">{{ins.type}}</text>
          <text class="insight-content">{{ins.content}}</text>
        </view>
      </view>
    </view>

    <!-- 在场 AI 专家 (第 1 刀只显数字; 第 5 刀做完整召唤 sheet) -->
    <view wx:if="{{detail.attending_agents && detail.attending_agents.length > 0}}" class="agents-bar">
      <text class="agents-label">在场 AI 专家 · {{detail.attending_agents.length}}</text>
      <view class="agents-list">
        <view
          wx:for="{{detail.attending_agents}}"
          wx:for-item="ag"
          wx:key="agent_id"
          class="agent-tag"
        >
          {{ag.nickname || ag.name}}
        </view>
      </view>
    </view>

    <!-- 实时转录 (第 2 刀) -->
    <view class="transcript-block">
      <view class="transcript-header">
        <view class="th-left">
          <text class="th-title">实时转录</text>
          <text class="th-count">{{transcriptLines.length}} 条</text>
        </view>
        <!-- WS 连接状态点 -->
        <view class="ws-state-{{wsState}}">
          <text wx:if="{{wsState === 'ready'}}">● 已就绪</text>
          <text wx:elif="{{wsState === 'connected'}}">○ 连接中…</text>
          <text wx:elif="{{wsState === 'connecting'}}">○ 连接中…</text>
          <text wx:elif="{{wsState === 'reconnecting'}}">○ 重连中…</text>
          <text wx:elif="{{wsState === 'closed'}}">⊘ 已断开</text>
          <text wx:else>⊘ 未连接</text>
        </view>
      </view>

      <scroll-view
        id="transcript-scroll"
        class="transcript-scroll"
        scroll-y
        scroll-into-view="{{transcriptScrollIntoView}}"
        scroll-with-animation
        enable-flex
        bindscrolltolower="onScrollToBottom"
        bindscroll="onTranscriptScroll"
        bindtouchend="onTranscriptTouchEnd"
      >
        <view wx:if="{{transcriptLines.length === 0}}" class="transcript-empty">
          <text wx:if="{{detail.status === 'ongoing'}}">等待发言…</text>
          <text wx:else>暂无转录</text>
        </view>
        <block wx:for="{{transcriptLines}}" wx:key="id">
          <!-- 真人 行 -->
          <view
            wx:if="{{item.kind === 'user'}}"
            id="{{item.id}}"
            class="transcript-line"
          >
            <view class="tl-head">
              <text class="tl-speaker">{{item.speakerName}}</text>
              <text wx:if="{{item.atMinute !== null && item.atMinute !== undefined}}" class="tl-time">{{item.atMinute}}m</text>
              <text wx:if="{{item.speakerStatus === 'manual'}}" class="tl-tag">手打</text>
              <text wx:if="{{item.speakerStatus === 'auto_recognized'}}" class="tl-tag tl-tag-auto">声纹</text>
            </view>
            <view class="tl-text">{{item.text}}</view>
          </view>

          <!-- AI 行 -->
          <view
            wx:elif="{{item.kind === 'agent'}}"
            id="{{item.id}}"
            class="agent-bubble agent-color-{{item.agentColor}}"
          >
            <view class="ab-head">
              <view class="ab-dot agent-bg-{{item.agentColor}}"></view>
              <text class="ab-name">{{item.agentNickname || item.agentName}}</text>
              <text wx:if="{{item.status === 'streaming'}}" class="ab-typing">正在说…</text>
              <text wx:if="{{item.citationsCount > 0}}" class="ab-citations">引用 {{item.citationsCount}}</text>
            </view>
            <view class="ab-text">
              {{item.text}}<text wx:if="{{item.status === 'streaming'}}" class="ab-cursor">▍</text>
            </view>
          </view>
        </block>
      </scroll-view>

      <!-- 用户上滑后, 累积新转录时显跳到底部按钮 -->
      <view
        wx:if="{{pendingNewCount > 0}}"
        class="jump-bottom-fab"
        bindtap="onJumpToBottom"
      >
        ↓ {{pendingNewCount}} 条新
      </view>
    </view>

    <!-- Footer 按钮 -->
    <view class="footer-bar">
      <button class="btn-secondary" bindtap="onBack">← 返回</button>
      <button class="btn-secondary" bindtap="onRefresh">↻ 刷新</button>
      <button
        wx:if="{{detail.status === 'ongoing'}}"
        class="btn-primary-inline"
        bindtap="onOpenSummonSheet"
      >💬 召唤 AI</button>
    </view>
  </view>

  <!-- 召唤 sheet (第 5 刀) — 底部弹起的抽屉, mask 全屏覆盖 -->
  <view
    wx:if="{{summonSheetOpen}}"
    class="sheet-mask"
    bindtap="onCloseSummonSheet"
    catchtouchmove="onCloseSummonSheet"
  ></view>
  <view class="sheet {{summonSheetOpen ? 'sheet-open' : ''}}">
    <view class="sheet-header">
      <view class="sheet-title">召唤 AI 专家</view>
      <view class="sheet-close" bindtap="onCloseSummonSheet">×</view>
    </view>

    <scroll-view scroll-y class="sheet-body">
      <!-- 会议中 section -->
      <view wx:if="{{detail.attending_agents && detail.attending_agents.length > 0}}" class="sheet-section">
        <view class="sheet-section-title">
          会议中 · {{detail.attending_agents.length}}
        </view>
        <view
          wx:for="{{detail.attending_agents}}"
          wx:key="agent_id"
          class="agent-row"
          data-id="{{item.agent_id}}"
          bindtap="onSheetSummonAgent"
        >
          <view class="ar-dot agent-bg-{{item.color || 'violet'}}"></view>
          <view class="ar-body">
            <view class="ar-name">{{item.nickname || item.name}}</view>
            <view class="ar-meta">
              <text wx:if="{{item.domain}}">{{item.domain}}</text>
              <text wx:if="{{item.role === 'moderator'}}" class="ar-role-moderator">主持人</text>
            </view>
          </view>
          <view class="ar-action">
            <text wx:if="{{summonBusyId === item.agent_id}}">…</text>
            <text wx:else>派他发言 →</text>
          </view>
        </view>
      </view>

      <!-- 可邀请 section -->
      <view wx:if="{{workspaceAgentsLoading}}" class="sheet-loading">加载中…</view>
      <view wx:elif="{{workspaceAgentsErr}}" class="sheet-error">{{workspaceAgentsErr}}</view>
      <view wx:elif="{{inviteableAgents.length > 0}}" class="sheet-section">
        <view class="sheet-section-title">
          可邀请 · {{inviteableAgents.length}}
        </view>
        <view
          wx:for="{{inviteableAgents}}"
          wx:key="id"
          class="agent-row"
          data-id="{{item.id}}"
          bindtap="onSheetSummonAgent"
        >
          <view class="ar-dot agent-bg-{{item.color || 'violet'}}"></view>
          <view class="ar-body">
            <view class="ar-name">{{item.nickname || item.name}}</view>
            <view class="ar-meta">
              <text wx:if="{{item.domain}}">{{item.domain}}</text>
              <text class="ar-role-not-invited">未邀请</text>
            </view>
          </view>
          <view class="ar-action">
            <text wx:if="{{summonBusyId === item.id}}">…</text>
            <text wx:else>邀请并发言 →</text>
          </view>
        </view>
      </view>
      <view wx:elif="{{workspaceAgents}}" class="sheet-empty">
        所有 AI 都已在会议中
      </view>
    </scroll-view>
  </view>

  <!-- 录音控制条 (第 3 刀) — 仅 ongoing 会议显, 固定底部 -->
  <view
    wx:if="{{detail && detail.status === 'ongoing'}}"
    class="mic-bar"
    style="padding-bottom: calc(20rpx + env(safe-area-inset-bottom));"
  >
    <!-- 左边: 状态点 + 文字 + 计时 -->
    <view class="mic-status">
      <view class="mic-dot mic-dot-{{micState}}"></view>
      <view class="mic-text">
        <text wx:if="{{micState === 'idle'}}">未录音</text>
        <text wx:elif="{{micState === 'starting'}}">启动中…</text>
        <text wx:elif="{{micState === 'recording'}}">录音中 · {{micElapsedStr}}</text>
        <text wx:elif="{{micState === 'paused'}}">已闭麦 · {{micElapsedStr}}</text>
        <text wx:elif="{{micState === 'stopping'}}">停止中…</text>
        <text wx:elif="{{micState === 'error'}}" class="mic-text-err">{{micError || '录音错误'}}</text>
      </view>
    </view>

    <!-- 右边: 按钮 -->
    <view class="mic-actions">
      <!-- 闭麦/解麦 — 仅录音/暂停 状态显 -->
      <button
        wx:if="{{micState === 'recording'}}"
        class="btn-mic-mute"
        bindtap="onMicToggleMute"
      >闭麦</button>
      <button
        wx:elif="{{micState === 'paused'}}"
        class="btn-mic-resume"
        bindtap="onMicToggleMute"
      >解麦</button>

      <!-- 主按钮 — 录音中显红色"停止", 否则显绿色"开始" -->
      <button
        wx:if="{{micState === 'recording' || micState === 'paused'}}"
        class="btn-mic-stop"
        bindtap="onMicMain"
      >停止</button>
      <button
        wx:else
        class="btn-mic-start"
        bindtap="onMicMain"
        disabled="{{micState === 'starting' || micState === 'stopping'}}"
      >🎙 开始录音</button>
    </view>
  </view>
</view>
