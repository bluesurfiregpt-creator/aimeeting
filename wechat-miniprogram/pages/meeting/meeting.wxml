<!-- pages/meeting/meeting.wxml — N-1 第 1 刀: 骨架 -->
<view class="container">

  <!-- Loading -->
  <view wx:if="{{loading}}" class="state-block">
    <view class="state-emoji">⏳</view>
    <view class="state-text">加载中…</view>
  </view>

  <!-- 开发模式 token 输入 -->
  <view wx:elif="{{needToken}}" class="state-block">
    <view class="state-emoji">🔑</view>
    <view class="state-title">需要 token</view>
    <view class="state-body">
      开发模式. 在 H5 端登录后, 在浏览器 console 调 `await fetch('/api/auth/token', {method:'POST',...})` 拿 token 粘贴到这里.
    </view>
    <textarea
      class="dev-input"
      placeholder="粘贴 token (eyJhb...)"
      value="{{devTokenInput}}"
      bindinput="onDevTokenInput"
      auto-height
    />
    <input
      class="dev-input-line"
      placeholder="(可选) expires_at ISO, 不填默认 30 天"
      value="{{devTokenExpInput}}"
      bindinput="onDevTokenExpInput"
    />
    <button class="btn-primary" bindtap="onDevTokenConfirm">确认</button>
    <view wx:if="{{error}}" class="state-error">{{error}}</view>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{error}}" class="state-block">
    <view class="state-emoji">⚠️</view>
    <view class="state-text">{{error}}</view>
    <button class="btn-secondary" bindtap="onRefresh">重试</button>
    <button class="btn-text" bindtap="onBack">返回</button>
  </view>

  <!-- 主内容 -->
  <view wx:elif="{{detail}}" class="meeting-body">

    <!-- 状态横条 -->
    <view class="status-bar status-{{detail.status}}">
      <text wx:if="{{detail.status === 'ongoing'}}">● 进行中 · 已 {{detail.started_minutes_ago}} 分钟</text>
      <text wx:elif="{{detail.status === 'scheduled'}}">○ 未开始</text>
      <text wx:elif="{{detail.status === 'finished'}}">✓ 已结束</text>
      <text wx:elif="{{detail.status === 'processed'}}">✓ 已沉淀</text>
      <text wx:else>{{detail.status}}</text>
    </view>

    <!-- 议程 chip 行 (横滑) -->
    <scroll-view wx:if="{{agendaChips.length > 0}}" scroll-x class="agenda-row">
      <view
        wx:for="{{agendaChips}}"
        wx:key="idx"
        class="agenda-chip {{item.toneClass}} {{item.isCurrent ? 'chip-highlight' : ''}}"
      >
        <view class="chip-icon">{{item.statusIcon}}</view>
        <view class="chip-title">{{item.title}}</view>
        <view wx:if="{{item.timeBudget}}" class="chip-meta">
          <text wx:if="{{item.elapsedMin !== null}}">{{item.elapsedMin}}/</text>{{item.timeBudget}}m
        </view>
      </view>
    </scroll-view>

    <!-- 当前议题 + Insights (第 1 刀只显文本占位; 第 4 刀做完整 AI 气泡) -->
    <view wx:if="{{detail.current_topic_title}}" class="current-topic">
      <view class="topic-label">当前议题</view>
      <view class="topic-title">{{detail.current_topic_title}}</view>
      <view wx:if="{{detail.current_topic_elapsed_min}}" class="topic-meta">
        已议 {{detail.current_topic_elapsed_min}} 分钟
      </view>
      <view wx:if="{{detail.current_topic_insights && detail.current_topic_insights.length > 0}}" class="insights-mini">
        <text class="insights-label">本议题 AI 快照 · {{detail.current_topic_insights.length}}</text>
        <view
          wx:for="{{detail.current_topic_insights}}"
          wx:for-item="ins"
          wx:key="id"
          class="insight-mini"
        >
          <text class="insight-type">{{ins.type}}</text>
          <text class="insight-content">{{ins.content}}</text>
        </view>
      </view>
    </view>

    <!-- 在场 AI 专家 (第 1 刀只显数字; 第 5 刀做完整召唤 sheet) -->
    <view wx:if="{{detail.attending_agents && detail.attending_agents.length > 0}}" class="agents-bar">
      <text class="agents-label">在场 AI 专家 · {{detail.attending_agents.length}}</text>
      <view class="agents-list">
        <view
          wx:for="{{detail.attending_agents}}"
          wx:for-item="ag"
          wx:key="agent_id"
          class="agent-tag"
        >
          {{ag.nickname || ag.name}}
        </view>
      </view>
    </view>

    <!-- 实时转录 (第 2 刀) -->
    <view class="transcript-block">
      <view class="transcript-header">
        <view class="th-left">
          <text class="th-title">实时转录</text>
          <text class="th-count">{{transcriptLines.length}} 条</text>
        </view>
        <!-- WS 连接状态点 -->
        <view class="ws-state-{{wsState}}">
          <text wx:if="{{wsState === 'ready'}}">● 已就绪</text>
          <text wx:elif="{{wsState === 'connected'}}">○ 连接中…</text>
          <text wx:elif="{{wsState === 'connecting'}}">○ 连接中…</text>
          <text wx:elif="{{wsState === 'reconnecting'}}">○ 重连中…</text>
          <text wx:elif="{{wsState === 'closed'}}">⊘ 已断开</text>
          <text wx:else>⊘ 未连接</text>
        </view>
      </view>

      <scroll-view
        id="transcript-scroll"
        class="transcript-scroll"
        scroll-y
        scroll-into-view="{{transcriptScrollIntoView}}"
        scroll-with-animation
        enable-flex
        bindscrolltolower="onScrollToBottom"
        bindscroll="onTranscriptScroll"
        bindtouchend="onTranscriptTouchEnd"
      >
        <view wx:if="{{transcriptLines.length === 0}}" class="transcript-empty">
          <text wx:if="{{detail.status === 'ongoing'}}">等待发言…</text>
          <text wx:else>暂无转录</text>
        </view>
        <view
          wx:for="{{transcriptLines}}"
          wx:key="id"
          id="{{item.id}}"
          class="transcript-line"
        >
          <view class="tl-head">
            <text class="tl-speaker">{{item.speakerName}}</text>
            <text wx:if="{{item.atMinute !== null && item.atMinute !== undefined}}" class="tl-time">{{item.atMinute}}m</text>
            <text wx:if="{{item.speakerStatus === 'manual'}}" class="tl-tag">手打</text>
            <text wx:if="{{item.speakerStatus === 'auto_recognized'}}" class="tl-tag tl-tag-auto">声纹</text>
          </view>
          <view class="tl-text">{{item.text}}</view>
        </view>
      </scroll-view>

      <!-- 用户上滑后, 累积新转录时显跳到底部按钮 -->
      <view
        wx:if="{{pendingNewCount > 0}}"
        class="jump-bottom-fab"
        bindtap="onJumpToBottom"
      >
        ↓ {{pendingNewCount}} 条新
      </view>
    </view>

    <!-- Footer 按钮 -->
    <view class="footer-bar">
      <button class="btn-secondary" bindtap="onBack">← 返回</button>
      <button class="btn-secondary" bindtap="onRefresh">↻ 刷新</button>
    </view>
  </view>
</view>
