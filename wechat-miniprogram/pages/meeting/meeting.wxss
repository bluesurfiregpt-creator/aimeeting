/* pages/meeting/meeting.wxss — N-1 第 1 刀 骨架 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  /* 给底部录音控制条留位 (~ 180rpx + safe-area). 没录音条 (非 ongoing) 时
     白多一些也没事, 比挡按钮强. */
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

/* ===== 状态块 (loading / 错误 / 缺 token) ===== */

.state-block {
  padding: 80rpx 48rpx;
  text-align: center;
}

.state-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 16rpx;
}

.state-text {
  font-size: 30rpx;
  color: #a1a1aa;
}

.state-body {
  margin: 16rpx 0 32rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #71717a;
  text-align: left;
  padding: 24rpx;
  background: #18181b;
  border-radius: 16rpx;
}

.state-error {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.dev-fallback-divider {
  margin: 48rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #52525b;
}

.dev-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  font-family: ui-monospace, "SF Mono", monospace;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.dev-input-line {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

/* ===== 按钮通用 ===== */

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 20rpx;
  text-align: center;
  margin-top: 16rpx;
}

.btn-secondary {
  height: 80rpx;
  line-height: 80rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  color: #e4e4e7;
  font-size: 28rpx;
  border-radius: 16rpx;
  text-align: center;
}

.btn-text {
  background: transparent;
  color: #71717a;
  font-size: 26rpx;
  line-height: 80rpx;
  margin-top: 16rpx;
}

/* ===== 主内容: 会议室 ===== */

.meeting-body {
  display: flex;
  flex-direction: column;
}

/* 状态横条 */
.status-bar {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-bottom: 1rpx solid #27272a;
  background: #18181b;
}

.status-ongoing {
  background: rgba(16, 185, 129, 0.08);
  color: #6ee7b7;
}

.status-finished, .status-processed {
  background: rgba(115, 115, 130, 0.08);
  color: #a1a1aa;
}

.status-scheduled {
  background: rgba(245, 158, 11, 0.08);
  color: #fcd34d;
}

/* 议程 chip 行 */
.agenda-row {
  white-space: nowrap;
  padding: 24rpx 32rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.agenda-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 20rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  vertical-align: top;
  max-width: 60vw;
}

.chip-pending { color: #71717a; }
.chip-active { color: #93c5fd; background: rgba(59, 130, 246, 0.08); border-color: rgba(59, 130, 246, 0.3); }
.chip-done { color: #86efac; }
.chip-highlight { box-shadow: 0 0 0 4rpx rgba(139, 92, 246, 0.3); }

.chip-icon {
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.chip-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.chip-meta {
  font-size: 22rpx;
  color: #71717a;
  flex-shrink: 0;
}

/* 当前议题块 */
.current-topic {
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #18181b;
  border-radius: 24rpx;
  border-left: 6rpx solid #8b5cf6;
}

.topic-label {
  font-size: 22rpx;
  color: #71717a;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 8rpx;
}

.topic-meta {
  font-size: 24rpx;
  color: #a1a1aa;
}

/* AI 快照 mini 列表 */
.insights-mini {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #27272a;
}

.insights-label {
  display: block;
  font-size: 22rpx;
  color: #71717a;
  margin-bottom: 12rpx;
}

.insight-mini {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.insight-type {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  background: rgba(139, 92, 246, 0.15);
  color: #c4b5fd;
  border-radius: 8rpx;
  font-size: 22rpx;
  align-self: flex-start;
}

.insight-content {
  flex: 1;
  color: #e4e4e7;
  line-height: 1.5;
}

/* 在场 AI 专家 */
.agents-bar {
  margin: 24rpx 32rpx 0;
  padding: 20rpx;
  background: #18181b;
  border-radius: 16rpx;
}

.agents-label {
  font-size: 22rpx;
  color: #71717a;
  margin-bottom: 12rpx;
  display: block;
}

.agents-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.agent-tag {
  padding: 6rpx 16rpx;
  background: rgba(139, 92, 246, 0.12);
  color: #c4b5fd;
  border-radius: 999rpx;
  font-size: 24rpx;
}

/* ===== 实时转录区 (第 2 刀) ===== */

.transcript-block {
  position: relative;
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #18181b;
  border-radius: 24rpx;
}

.transcript-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.th-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.th-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fafafa;
}

.th-count {
  font-size: 22rpx;
  color: #71717a;
}

/* WS 连接状态 */
.ws-state-ready {
  font-size: 22rpx;
  color: #6ee7b7;
}

.ws-state-connected,
.ws-state-connecting,
.ws-state-reconnecting {
  font-size: 22rpx;
  color: #fcd34d;
}

.ws-state-closed,
.ws-state-idle {
  font-size: 22rpx;
  color: #71717a;
}

/* scroll-view */
.transcript-scroll {
  height: 800rpx;          /* 固定高度让 scroll-view 工作; 后续刀可调 */
  background: #0f0f12;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.transcript-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #71717a;
  font-size: 26rpx;
}

/* 单行 */
.transcript-line {
  margin-bottom: 20rpx;
}

.tl-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tl-speaker {
  font-size: 24rpx;
  font-weight: 600;
  color: #a1a1aa;
}

.tl-time {
  font-size: 22rpx;
  color: #52525b;
  font-variant-numeric: tabular-nums;
}

.tl-tag {
  padding: 1rpx 8rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  background: rgba(115, 115, 130, 0.15);
  color: #a1a1aa;
}

.tl-tag-auto {
  background: rgba(16, 185, 129, 0.12);
  color: #6ee7b7;
}

.tl-text {
  font-size: 28rpx;
  line-height: 1.55;
  color: #e4e4e7;
  word-break: break-word;
}

/* ===== AI 气泡 (第 4 刀) ===== */

.agent-bubble {
  margin: 0 0 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(139, 92, 246, 0.08);
  border-left: 4rpx solid #8b5cf6;
  border-radius: 12rpx;
}

/* agent color 变体 — 左边色条 + 微妙 tint */
.agent-color-violet { border-left-color: #8b5cf6; background: rgba(139, 92, 246, 0.08); }
.agent-color-emerald { border-left-color: #10b981; background: rgba(16, 185, 129, 0.08); }
.agent-color-amber { border-left-color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
.agent-color-sky { border-left-color: #0ea5e9; background: rgba(14, 165, 233, 0.08); }
.agent-color-rose { border-left-color: #f43f5e; background: rgba(244, 63, 94, 0.08); }
.agent-color-teal { border-left-color: #14b8a6; background: rgba(20, 184, 166, 0.08); }
.agent-color-blue { border-left-color: #3b82f6; background: rgba(59, 130, 246, 0.08); }
.agent-color-indigo { border-left-color: #6366f1; background: rgba(99, 102, 241, 0.08); }

.ab-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.ab-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.agent-bg-violet { background: #8b5cf6; }
.agent-bg-emerald { background: #10b981; }
.agent-bg-amber { background: #f59e0b; }
.agent-bg-sky { background: #0ea5e9; }
.agent-bg-rose { background: #f43f5e; }
.agent-bg-teal { background: #14b8a6; }
.agent-bg-blue { background: #3b82f6; }
.agent-bg-indigo { background: #6366f1; }

.ab-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #c4b5fd;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ab-typing {
  font-size: 22rpx;
  color: #a78bfa;
  padding: 1rpx 10rpx;
  background: rgba(139, 92, 246, 0.18);
  border-radius: 8rpx;
  flex-shrink: 0;
  animation: typingPulse 1.4s ease-in-out infinite;
}

@keyframes typingPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.ab-citations {
  font-size: 22rpx;
  color: #71717a;
  flex-shrink: 0;
}

.ab-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #f4f4f5;
  word-break: break-word;
}

.ab-cursor {
  display: inline-block;
  color: #a78bfa;
  margin-left: 4rpx;
  animation: cursorBlink 1s steps(2, end) infinite;
}

@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  50.01%, 100% { opacity: 0; }
}

/* ===== 议程 banner (第 4 刀) ===== */

.banner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 16rpx 32rpx 0;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
  position: relative;
}

.banner-info {
  background: rgba(59, 130, 246, 0.08);
  border-color: rgba(59, 130, 246, 0.3);
}
.banner-info .banner-title { color: #93c5fd; }

.banner-warning {
  background: rgba(245, 158, 11, 0.10);
  border-color: rgba(245, 158, 11, 0.35);
}
.banner-warning .banner-title { color: #fcd34d; }

.banner-severe {
  background: rgba(244, 63, 94, 0.12);
  border-color: rgba(244, 63, 94, 0.4);
}
.banner-severe .banner-title { color: #fda4af; }

.banner-success {
  background: rgba(16, 185, 129, 0.10);
  border-color: rgba(16, 185, 129, 0.35);
}
.banner-success .banner-title { color: #6ee7b7; }

.banner-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-top: 2rpx;
  flex-shrink: 0;
}

.banner-body {
  flex: 1;
  min-width: 0;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.banner-countdown {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 10rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  color: #fafafa;
  font-variant-numeric: tabular-nums;
}

.banner-text {
  font-size: 26rpx;
  color: #e4e4e7;
  line-height: 1.5;
  word-break: break-word;
}

.banner-sub {
  font-size: 24rpx;
  color: #a1a1aa;
  margin-top: 6rpx;
}

.banner-close {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #71717a;
  border-radius: 50%;
}

.banner-close:active {
  background: rgba(255, 255, 255, 0.08);
}

/* banner "立刻召唤" 按钮 (第 5 刀) */
.banner-actions {
  margin-top: 12rpx;
}

.btn-banner-summon {
  display: inline-block;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  margin: 0;
}

.btn-banner-summon::after {
  border: none;
}

/* ===== Footer 召唤入口 — 紫色按钮 (第 5 刀) ===== */

.btn-primary-inline {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}

.btn-primary-inline::after { border: none; }

/* ===== 召唤 sheet (第 5 刀) ===== */

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  backdrop-filter: blur(4rpx);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 101;
  background: #18181b;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.sheet-open {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #27272a;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fafafa;
}

.sheet-close {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: #71717a;
  border-radius: 50%;
}

.sheet-close:active {
  background: rgba(255, 255, 255, 0.08);
}

.sheet-body {
  flex: 1;
  padding: 8rpx 0 16rpx;
  min-height: 200rpx;
  max-height: 70vh;
}

.sheet-section {
  padding: 16rpx 0;
}

.sheet-section-title {
  padding: 12rpx 32rpx 8rpx;
  font-size: 24rpx;
  color: #71717a;
  font-weight: 500;
}

.agent-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  transition: background 0.15s;
}

.agent-row:active {
  background: rgba(255, 255, 255, 0.04);
}

.ar-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ar-body {
  flex: 1;
  min-width: 0;
}

.ar-name {
  font-size: 30rpx;
  color: #fafafa;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ar-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #71717a;
}

.ar-role-moderator {
  padding: 1rpx 8rpx;
  background: rgba(245, 158, 11, 0.15);
  color: #fcd34d;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.ar-role-not-invited {
  padding: 1rpx 8rpx;
  background: rgba(115, 115, 130, 0.15);
  color: #a1a1aa;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.ar-action {
  font-size: 24rpx;
  color: #a78bfa;
  flex-shrink: 0;
}

.sheet-loading,
.sheet-error,
.sheet-empty {
  padding: 40rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #71717a;
}

.sheet-error {
  color: #fda4af;
}

/* 跳到底部 fab */
.jump-bottom-fab {
  position: absolute;
  left: 50%;
  bottom: 88rpx;
  transform: translateX(-50%);
  padding: 12rpx 24rpx;
  background: rgba(139, 92, 246, 0.95);
  color: #fff;
  font-size: 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.4);
  z-index: 10;
}

/* ===== 录音控制条 (第 3 刀) — 固定底部, ongoing 时显 ===== */

.mic-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: rgba(15, 15, 18, 0.96);
  border-top: 1rpx solid #27272a;
  backdrop-filter: blur(8rpx);
}

.mic-status {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.mic-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #52525b;
}

.mic-dot-idle { background: #52525b; }
.mic-dot-starting,
.mic-dot-stopping {
  background: #fcd34d;
  animation: micPulse 1.2s ease-in-out infinite;
}
.mic-dot-recording {
  background: #f43f5e;
  animation: micPulse 1.0s ease-in-out infinite;
  box-shadow: 0 0 12rpx rgba(244, 63, 94, 0.6);
}
.mic-dot-paused {
  background: #a78bfa;
}
.mic-dot-error { background: #f43f5e; }

@keyframes micPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.85); }
}

.mic-text {
  font-size: 26rpx;
  color: #e4e4e7;
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mic-text-err { color: #fda4af; }

.mic-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-mic-start,
.btn-mic-stop,
.btn-mic-mute,
.btn-mic-resume {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  margin: 0;
  font-weight: 500;
}

.btn-mic-start {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
}

.btn-mic-start[disabled] {
  opacity: 0.5;
}

.btn-mic-stop {
  background: linear-gradient(135deg, #f43f5e, #e11d48);
  color: #fff;
}

.btn-mic-mute,
.btn-mic-resume {
  background: #27272a;
  color: #e4e4e7;
  border: 1rpx solid #3f3f46;
}

/* 微信 button 默认有 border + padding, 去掉 */
.mic-actions button::after {
  border: none;
}

/* Footer 按钮 */
.footer-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx 0;
}

.footer-bar .btn-secondary {
  flex: 1;
}
