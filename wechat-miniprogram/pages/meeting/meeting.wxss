/* pages/meeting/meeting.wxss — v1.4.0 Saga F (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  font-family: -apple-system, "SF Pro Text", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  /* 给底部录音控制条留位 (~ 180rpx + safe-area). 没录音条 (非 ongoing) 时
     白多一些也没事, 比挡按钮强. */
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

/* ===== 状态块 (loading / 错误 / 缺 token) ===== */

.state-block {
  padding: 80rpx 48rpx;
  text-align: center;
}

.state-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 16rpx;
}

.state-text {
  font-size: 30rpx;
  color: #3C3C43;
}

.state-body {
  margin: 16rpx 0 32rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #8E8E93;
  text-align: left;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.state-error {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.dev-fallback-divider {
  margin: 48rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
}

.dev-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 24rpx;
  font-family: ui-monospace, "SF Mono", monospace;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.dev-input-line {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

/* ===== 按钮通用 ===== */

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #007AFF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 20rpx;
  text-align: center;
  margin-top: 16rpx;
}

.btn-secondary {
  height: 80rpx;
  line-height: 80rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  color: #1C1C1E;
  font-size: 28rpx;
  border-radius: 16rpx;
  text-align: center;
}

.btn-text {
  background: transparent;
  color: #8E8E93;
  font-size: 26rpx;
  line-height: 80rpx;
  margin-top: 16rpx;
}

/* ===== 主内容: 会议室 ===== */

.meeting-body {
  display: flex;
  flex-direction: column;
}

/* 状态横条 */
.status-bar {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
  background: #FFFFFF;
}

.status-ongoing {
  background: rgba(52, 199, 89, 0.08);
  color: #0F9D58;
}

.status-finished, .status-processed {
  background: #F7F7F9;
  color: #3C3C43;
}

.status-scheduled {
  background: rgba(255, 159, 10, 0.10);
  color: #8B6914;
}

/* 议程 chip 行 */
.agenda-row {
  white-space: nowrap;
  padding: 24rpx 32rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.agenda-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 20rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  vertical-align: top;
  max-width: 60vw;
}

.chip-pending  { color: #8E8E93; }
.chip-active   { color: #007AFF; background: rgba(0, 122, 255, 0.08); border-color: rgba(0, 122, 255, 0.30); }
.chip-done     { color: #0F9D58; }
.chip-highlight { box-shadow: 0 0 0 4rpx rgba(94, 92, 230, 0.25); }

.chip-icon {
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.chip-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.chip-meta {
  font-size: 22rpx;
  color: #8E8E93;
  flex-shrink: 0;
}

/* 当前议题块 */
.current-topic {
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border-left: 6rpx solid #5E5CE6;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.topic-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}

.topic-meta {
  font-size: 24rpx;
  color: #3C3C43;
}

/* AI 快照 mini 列表 */
.insights-mini {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}

.insights-label {
  display: block;
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
}

.insight-mini {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.insight-type {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  background: rgba(94, 92, 230, 0.12);
  color: #5E5CE6;
  border-radius: 8rpx;
  font-size: 22rpx;
  align-self: flex-start;
}

.insight-content {
  flex: 1;
  color: #1C1C1E;
  line-height: 1.5;
}

/* 在场 AI 专家 */
.agents-bar {
  margin: 24rpx 32rpx 0;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.agents-label {
  font-size: 22rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
  display: block;
}

.agents-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.agent-tag {
  padding: 6rpx 16rpx;
  background: rgba(94, 92, 230, 0.10);
  color: #5E5CE6;
  border-radius: 999rpx;
  font-size: 24rpx;
}

/* ===== 实时转录区 ===== */

.transcript-block {
  position: relative;
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.transcript-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.th-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.th-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.th-count {
  font-size: 22rpx;
  color: #8E8E93;
}

/* WS 连接状态 */
.ws-state-ready {
  font-size: 22rpx;
  color: #0F9D58;
}

.ws-state-connected,
.ws-state-connecting,
.ws-state-reconnecting {
  font-size: 22rpx;
  color: #8B6914;
}

.ws-state-closed,
.ws-state-idle {
  font-size: 22rpx;
  color: #8E8E93;
}

/* scroll-view */
.transcript-scroll {
  height: 800rpx;
  background: #F7F7F9;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.transcript-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #8E8E93;
  font-size: 26rpx;
}

/* 单行 */
.transcript-line {
  margin-bottom: 20rpx;
}

.tl-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tl-speaker {
  font-size: 24rpx;
  font-weight: 600;
  color: #3C3C43;
}

.tl-time {
  font-size: 22rpx;
  color: #C7C7CC;
  font-variant-numeric: tabular-nums;
}

.tl-tag {
  padding: 1rpx 8rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  background: #E5E5EA;
  color: #3C3C43;
}

.tl-tag-auto {
  background: rgba(52, 199, 89, 0.10);
  color: #0F9D58;
}

.tl-text {
  font-size: 28rpx;
  line-height: 1.55;
  color: #1C1C1E;
  word-break: break-word;
}

/* ===== AI 气泡 ===== */

.agent-bubble {
  margin: 0 0 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(94, 92, 230, 0.06);
  border-left: 4rpx solid #5E5CE6;
  border-radius: 12rpx;
}

/* agent color 变体 — iOS 系统色 + 浅 tint */
.agent-color-violet  { border-left-color: #5E5CE6; background: rgba(94, 92, 230, 0.06); }
.agent-color-emerald { border-left-color: #34C759; background: rgba(52, 199, 89, 0.06); }
.agent-color-amber   { border-left-color: #FF9F0A; background: rgba(255, 159, 10, 0.06); }
.agent-color-sky     { border-left-color: #007AFF; background: rgba(0, 122, 255, 0.06); }
.agent-color-rose    { border-left-color: #FF375F; background: rgba(255, 55, 95, 0.06); }
.agent-color-teal    { border-left-color: #30B0C7; background: rgba(48, 176, 199, 0.06); }
.agent-color-blue    { border-left-color: #007AFF; background: rgba(0, 122, 255, 0.06); }
.agent-color-indigo  { border-left-color: #5E5CE6; background: rgba(94, 92, 230, 0.06); }

.ab-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.ab-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.agent-bg-violet  { background: #5E5CE6; }
.agent-bg-emerald { background: #34C759; }
.agent-bg-amber   { background: #FF9F0A; }
.agent-bg-sky     { background: #007AFF; }
.agent-bg-rose    { background: #FF375F; }
.agent-bg-teal    { background: #30B0C7; }
.agent-bg-blue    { background: #007AFF; }
.agent-bg-indigo  { background: #5E5CE6; }

.ab-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #5E5CE6;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ab-typing {
  font-size: 22rpx;
  color: #5E5CE6;
  padding: 1rpx 10rpx;
  background: rgba(94, 92, 230, 0.16);
  border-radius: 8rpx;
  flex-shrink: 0;
  animation: typingPulse 1.4s ease-in-out infinite;
}

@keyframes typingPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.ab-citations {
  font-size: 22rpx;
  color: #8E8E93;
  flex-shrink: 0;
}

.ab-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1C1C1E;
  word-break: break-word;
}

.ab-cursor {
  display: inline-block;
  color: #5E5CE6;
  margin-left: 4rpx;
  animation: cursorBlink 1s steps(2, end) infinite;
}

@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  50.01%, 100% { opacity: 0; }
}

/* ===== 议程 banner ===== */

.banner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 16rpx 32rpx 0;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
  position: relative;
}

.banner-info {
  background: rgba(0, 122, 255, 0.06);
  border-color: rgba(0, 122, 255, 0.30);
}
.banner-info .banner-title { color: #007AFF; }

.banner-warning {
  background: rgba(255, 159, 10, 0.08);
  border-color: rgba(255, 159, 10, 0.35);
}
.banner-warning .banner-title { color: #8B6914; }

.banner-severe {
  background: rgba(255, 59, 48, 0.08);
  border-color: rgba(255, 59, 48, 0.40);
}
.banner-severe .banner-title { color: #C9302C; }

.banner-success {
  background: rgba(52, 199, 89, 0.08);
  border-color: rgba(52, 199, 89, 0.35);
}
.banner-success .banner-title { color: #0F9D58; }

.banner-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-top: 2rpx;
  flex-shrink: 0;
}

.banner-body {
  flex: 1;
  min-width: 0;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.banner-countdown {
  font-size: 22rpx;
  font-weight: 500;
  padding: 2rpx 10rpx;
  background: rgba(60, 60, 67, 0.10);
  border-radius: 8rpx;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
}

.banner-text {
  font-size: 26rpx;
  color: #1C1C1E;
  line-height: 1.5;
  word-break: break-word;
}

.banner-sub {
  font-size: 24rpx;
  color: #3C3C43;
  margin-top: 6rpx;
}

.banner-close {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #8E8E93;
  border-radius: 50%;
}

.banner-close:active {
  background: rgba(60, 60, 67, 0.08);
}

/* banner "立刻召唤" 按钮 */
.banner-actions {
  margin-top: 12rpx;
}

.btn-banner-summon {
  display: inline-block;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  background: #5E5CE6;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  margin: 0;
}

.btn-banner-summon::after {
  border: none;
}

/* ===== Footer 召唤入口 — iOS blue ===== */

.btn-primary-inline {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #007AFF;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  margin: 0;
  box-shadow: 0 3rpx 8rpx rgba(0, 122, 255, 0.20);
}

.btn-primary-inline::after { border: none; }

/* ===== 召唤 sheet ===== */

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 100;
  backdrop-filter: blur(4rpx);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 101;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.sheet-open {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.sheet-close {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: #8E8E93;
  border-radius: 50%;
}

.sheet-close:active {
  background: rgba(60, 60, 67, 0.08);
}

.sheet-body {
  flex: 1;
  padding: 8rpx 0 16rpx;
  min-height: 200rpx;
  max-height: 70vh;
}

.sheet-section {
  padding: 16rpx 0;
}

.sheet-section-title {
  padding: 12rpx 32rpx 8rpx;
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.agent-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  transition: background 0.15s;
}

.agent-row:active {
  background: #F7F7F9;
}

.ar-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ar-body {
  flex: 1;
  min-width: 0;
}

.ar-name {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ar-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

.ar-role-moderator {
  padding: 1rpx 8rpx;
  background: rgba(255, 159, 10, 0.12);
  color: #8B6914;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.ar-role-not-invited {
  padding: 1rpx 8rpx;
  background: #E5E5EA;
  color: #3C3C43;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.ar-action {
  font-size: 24rpx;
  color: #007AFF;
  flex-shrink: 0;
}

.sheet-loading,
.sheet-error,
.sheet-empty {
  padding: 40rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8E8E93;
}

.sheet-error {
  color: #C9302C;
}

/* 跳到底部 fab */
.jump-bottom-fab {
  position: absolute;
  left: 50%;
  bottom: 88rpx;
  transform: translateX(-50%);
  padding: 12rpx 24rpx;
  background: rgba(0, 122, 255, 0.95);
  color: #fff;
  font-size: 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 122, 255, 0.30);
  z-index: 10;
}

/* ===== 录音控制条 — 固定底部, ongoing 时显 ===== */

.mic-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
  backdrop-filter: blur(8rpx);
}

.mic-status {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.mic-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #C7C7CC;
}

.mic-dot-idle { background: #C7C7CC; }
.mic-dot-starting,
.mic-dot-stopping {
  background: #FF9F0A;
  animation: micPulse 1.2s ease-in-out infinite;
}
.mic-dot-recording {
  background: #FF3B30;
  animation: micPulse 1.0s ease-in-out infinite;
  box-shadow: 0 0 12rpx rgba(255, 59, 48, 0.50);
}
.mic-dot-paused {
  background: #5E5CE6;
}
.mic-dot-error { background: #FF3B30; }

@keyframes micPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.85); }
}

.mic-text {
  font-size: 26rpx;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mic-text-err { color: #C9302C; }

.mic-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-mic-start,
.btn-mic-stop,
.btn-mic-mute,
.btn-mic-resume {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  margin: 0;
  font-weight: 500;
}

.btn-mic-start {
  background: #34C759;
  color: #fff;
}

.btn-mic-start[disabled] {
  opacity: 0.5;
}

.btn-mic-stop {
  background: #FF3B30;
  color: #fff;
}

.btn-mic-mute,
.btn-mic-resume {
  background: #F7F7F9;
  color: #1C1C1E;
  border: 1rpx solid #D1D1D6;
}

/* 微信 button 默认有 border + padding, 去掉 */
.mic-actions button::after {
  border: none;
}

/* Footer 按钮 */
.footer-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx 0;
}

.footer-bar .btn-secondary {
  flex: 1;
}
