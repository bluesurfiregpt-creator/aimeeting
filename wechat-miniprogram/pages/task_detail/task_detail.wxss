/* pages/task_detail/task_detail.wxss — v1.4.0 Saga F 任务详情 (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Skeleton / Error ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-of-type { margin-top: 24rpx; }
.sk-card { height: 240rpx; }
.sk-row { height: 160rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.centered {
  padding: 100rpx 48rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #1C1C1E; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #8E8E93; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 0;
}

.sec-title {
  margin: 28rpx 4rpx 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #3C3C43;
}

/* ============ 通用卡 ============ */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

/* ============ Header ============ */
.task-content {
  font-size: 32rpx;
  color: #1C1C1E;
  line-height: 1.5;
}
.chip-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.source-link {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #007AFF;
}
.source-link-hover {
  opacity: 0.6;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(94, 92, 230, 0.12);  color: #5E5CE6; }
.tone-amber   { background: rgba(255, 159, 10, 0.12); color: #8B6914; }
.tone-rose    { background: rgba(255, 59, 48, 0.10);  color: #C9302C; }
.tone-cyan    { background: rgba(48, 176, 199, 0.12); color: #0E7C8E; }
.tone-emerald { background: rgba(52, 199, 89, 0.12);  color: #0F9D58; }
.tone-sky     { background: rgba(0, 122, 255, 0.10);  color: #007AFF; }
.tone-zinc    { background: #E5E5EA; color: #3C3C43; }

/* ============ Insight 卡 ============ */
.insight-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.insight-agent {
  font-size: 24rpx;
  color: #3C3C43;
}
.insight-content {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  line-height: 1.55;
}
.insight-evidence {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  background: #F7F7F9;
  border-left: 4rpx solid #D1D1D6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #3C3C43;
  line-height: 1.5;
}

/* ============ 实录依据 ============ */
.evidence-quote {
  border-left: 6rpx solid #C7C7CC;
  padding-left: 20rpx;
  font-size: 28rpx;
  font-style: italic;
  color: #1C1C1E;
  line-height: 1.6;
}
.evidence-lines {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #E5E5EA;
}
.ev-line {
  margin-bottom: 16rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.ev-min {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}
.ev-speaker {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 500;
  color: #3C3C43;
}
.ev-text {
  flex: 1;
  font-size: 26rpx;
  color: #1C1C1E;
  line-height: 1.5;
}

/* ============ 评论 ============ */
.comment-empty {
  border: 2rpx dashed #D1D1D6;
  border-radius: 16rpx;
  padding: 36rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8E8E93;
}
.comment-card {
  padding: 24rpx 28rpx;
}
.comment-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.comment-meta {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.comment-author {
  font-size: 26rpx;
  font-weight: 500;
  color: #1C1C1E;
}
.comment-when {
  font-size: 22rpx;
  color: #8E8E93;
}
.comment-del {
  font-size: 22rpx;
  color: #8E8E93;
  padding: 4rpx 8rpx;
}
.comment-content {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.6;
  white-space: pre-wrap;
}

.bottom-pad { height: 40rpx; }

/* ============ 发评论 bar ============ */
.comment-bar {
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}
.comment-input {
  flex: 1;
  min-height: 64rpx;
  max-height: 200rpx;
  padding: 16rpx 20rpx;
  background: #F7F7F9;
  border: 2rpx solid #E5E5EA;
  border-radius: 18rpx;
  color: #1C1C1E;
  font-size: 28rpx;
  box-sizing: border-box;
}
.ph { color: #C7C7CC; }
.comment-send {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007AFF;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 18rpx;
}
.comment-send-off {
  background: #E5E5EA;
  color: #C7C7CC;
}
