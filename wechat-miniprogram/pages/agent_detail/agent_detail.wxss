/* pages/agent_detail/agent_detail.wxss — v27.2 专家详情 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Skeleton / Error ============ */
.sk {
  background: #18181b;
  border-radius: 24rpx;
  margin: 0 32rpx 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-of-type { margin-top: 24rpx; }
.sk-card { height: 200rpx; }
.sk-row { height: 96rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.centered {
  padding: 100rpx 48rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #fafafa; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #a1a1aa; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 24rpx;
  color: #e4e4e7;
  font-size: 28rpx;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 0;
}

/* ============ 档案区 ============ */
.profile {
  display: flex;
  background: #18181b;
  border-radius: 24rpx;
  overflow: hidden;
}
.profile-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.bar-violet { background: #8b5cf6; }
.bar-emerald { background: #10b981; }
.bar-amber { background: #f59e0b; }
.bar-sky { background: #0ea5e9; }
.bar-rose { background: #f43f5e; }
.bar-teal { background: #14b8a6; }
.bar-blue { background: #3b82f6; }
.bar-indigo { background: #6366f1; }
.bar-zinc { background: #3f3f46; }

.profile-body {
  flex: 1;
  padding: 28rpx;
  min-width: 0;
}
.profile-sub {
  font-size: 26rpx;
  color: #a1a1aa;
  margin-bottom: 16rpx;
}
.profile-stats {
  display: flex;
  gap: 40rpx;
}
.stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #fafafa;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 24rpx;
  color: #a1a1aa;
}
.profile-active {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #71717a;
}

/* ============ Segment ============ */
.segment {
  margin: 24rpx 0 16rpx;
  display: flex;
  background: rgba(24, 24, 27, 0.6);
  border-radius: 24rpx;
  padding: 8rpx;
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #d4d4d8;
  border-radius: 18rpx;
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-on {
  background: #3f3f46;
  color: #fafafa;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

/* ============ 列表 / 卡片 ============ */
.group-title {
  margin: 24rpx 4rpx 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #a1a1aa;
}
.card {
  background: #18181b;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.card-hover {
  transform: scale(0.985);
  background: #1f1f23;
}
.card-muted {
  opacity: 0.6;
}

.row-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}
.row-date {
  font-size: 22rpx;
  color: #71717a;
}
.row-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #fafafa;
  line-height: 1.45;
}
.row-title-muted {
  color: #a1a1aa;
  text-decoration: line-through;
}
.row-extra {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #c4b5fd;
}
.row-extra-mute {
  color: #71717a;
}

/* Insight 内容 */
.insight-content {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #e4e4e7;
  line-height: 1.55;
}
.insight-evidence {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.03);
  border-left: 4rpx solid #3f3f46;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.5;
}

/* ============ Badge ============ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(139, 92, 246, 0.15); color: #c4b5fd; }
.tone-amber   { background: rgba(245, 158, 11, 0.15); color: #fcd34d; }
.tone-rose    { background: rgba(244, 63, 94, 0.15); color: #fda4af; }
.tone-cyan    { background: rgba(6, 182, 212, 0.15); color: #67e8f9; }
.tone-emerald { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
.tone-sky     { background: rgba(14, 165, 233, 0.15); color: #7dd3fc; }
.tone-zinc    { background: #27272a; color: #a1a1aa; }

/* ============ Empty ============ */
.empty-hint {
  margin-top: 12rpx;
  border: 2rpx dashed #3f3f46;
  border-radius: 20rpx;
  padding: 48rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #71717a;
}

.bottom-pad {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ 入场动效 ============ */
@keyframes tab-enter-anim {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.tab-enter {
  animation: tab-enter-anim 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}
