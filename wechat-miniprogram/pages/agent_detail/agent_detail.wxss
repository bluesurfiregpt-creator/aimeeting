/* pages/agent_detail/agent_detail.wxss — v1.4.0 Saga F 专家详情 (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Skeleton / Error ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-of-type { margin-top: 24rpx; }
.sk-card { height: 200rpx; }
.sk-row { height: 96rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.centered {
  padding: 100rpx 48rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #1C1C1E; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #8E8E93; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 0;
}

/* ============ 档案区 ============ */
.profile {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.profile-bar {
  width: 8rpx;
  flex-shrink: 0;
}
/* AI 专家个人色 — iOS 系统色版 (bundle 渐变只取主色) */
.bar-violet  { background: #5E5CE6; }
.bar-emerald { background: #34C759; }
.bar-amber   { background: #FF9F0A; }
.bar-sky     { background: #007AFF; }
.bar-rose    { background: #FF375F; }
.bar-teal    { background: #30B0C7; }
.bar-blue    { background: #007AFF; }
.bar-indigo  { background: #5E5CE6; }
.bar-zinc    { background: #C7C7CC; }

.profile-body {
  flex: 1;
  padding: 28rpx;
  min-width: 0;
}
.profile-sub {
  font-size: 26rpx;
  color: #8E8E93;
  margin-bottom: 16rpx;
}
.profile-stats {
  display: flex;
  gap: 40rpx;
}
.stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 24rpx;
  color: #8E8E93;
}
.profile-active {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

/* ============ Segment ============ */
.segment {
  margin: 24rpx 0 16rpx;
  display: flex;
  background: #E5E5EA;
  border-radius: 24rpx;
  padding: 8rpx;
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #3C3C43;
  border-radius: 18rpx;
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-on {
  background: #FFFFFF;
  color: #1C1C1E;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* ============ 列表 / 卡片 ============ */
.group-title {
  margin: 24rpx 4rpx 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #8E8E93;
}
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease, background 0.15s ease;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.card-hover {
  transform: scale(0.985);
  background: #F7F7F9;
}
.card-muted {
  opacity: 0.6;
}

.row-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}
.row-date {
  font-size: 22rpx;
  color: #8E8E93;
}
.row-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  line-height: 1.45;
}
.row-title-muted {
  color: #8E8E93;
  text-decoration: line-through;
}
.row-extra {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #007AFF;
}
.row-extra-mute {
  color: #8E8E93;
}

/* Insight 内容 */
.insight-content {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  line-height: 1.55;
}
.insight-evidence {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  background: #F7F7F9;
  border-left: 4rpx solid #D1D1D6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.5;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(94, 92, 230, 0.12);  color: #5E5CE6; }
.tone-amber   { background: rgba(255, 159, 10, 0.12); color: #8B6914; }
.tone-rose    { background: rgba(255, 59, 48, 0.10);  color: #C9302C; }
.tone-cyan    { background: rgba(48, 176, 199, 0.12); color: #0E7C8E; }
.tone-emerald { background: rgba(52, 199, 89, 0.12);  color: #0F9D58; }
.tone-sky     { background: rgba(0, 122, 255, 0.10);  color: #007AFF; }
.tone-zinc    { background: #E5E5EA; color: #3C3C43; }

/* ============ Empty ============ */
.empty-hint {
  margin-top: 12rpx;
  border: 2rpx dashed #D1D1D6;
  border-radius: 20rpx;
  padding: 48rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8E8E93;
}

.bottom-pad {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ 入场动效 ============ */
@keyframes tab-enter-anim {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.tab-enter {
  animation: tab-enter-anim 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}
