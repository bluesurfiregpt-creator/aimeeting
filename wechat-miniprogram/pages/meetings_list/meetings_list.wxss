/* pages/meetings_list/meetings_list.wxss — v1.4.0 Saga F (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
.hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.hd-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1;
  letter-spacing: -0.5rpx;
}
.hd-segment {
  margin-top: 32rpx;
  display: flex;
  background: #E5E5EA;
  border-radius: 24rpx;
  padding: 8rpx;
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 18rpx;
  color: #3C3C43;
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-label {
  font-size: 28rpx;
}
.seg-count {
  font-size: 24rpx;
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}
.seg-on {
  background: #FFFFFF;
  color: #1C1C1E;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}
.seg-on .seg-count {
  color: #3C3C43;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

/* "+ 新建会议" */
.new-btn-wrap {
  padding-top: 16rpx;
  padding-bottom: 12rpx;
}
.new-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(0, 122, 255, 0.06);
  border: 2rpx solid rgba(0, 122, 255, 0.30);
  border-radius: 24rpx;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 500;
  transition: transform 0.15s ease, background 0.15s ease;
}
.new-btn-hover {
  transform: scale(0.985);
  background: rgba(0, 122, 255, 0.12);
}
.new-btn-plus {
  font-size: 38rpx;
  line-height: 1;
}
.new-btn-label {
  font-size: 30rpx;
}

/* ============ Skeleton ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk-row { height: 180rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Empty / Error / Centered ============ */
.empty-card {
  margin-top: 24rpx;
  padding: 80rpx 32rpx;
  border: 2rpx dashed #D1D1D6;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8E8E93;
}
.centered {
  padding: 80rpx 32rpx;
  text-align: center;
}
.centered-title {
  font-size: 32rpx;
  color: #1C1C1E;
}
.centered-body {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.6;
}
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ Meeting card ============ */
.meeting-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  transition: transform 0.15s ease, background 0.15s ease;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.meeting-hover {
  transform: scale(0.985);
  background: #F7F7F9;
}

.meeting-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.meeting-time {
  flex: 1;
  font-size: 24rpx;
  color: #3C3C43;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.time-over {
  color: #8B6914;
}

.meeting-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meeting-meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24rpx 28rpx;
  font-size: 26rpx;
  color: #3C3C43;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.meta-icon {
  font-size: 26rpx;
}
.meta-num {
  font-variant-numeric: tabular-nums;
}
.meta-label {
  margin-left: 4rpx;
  font-size: 24rpx;
  color: #8E8E93;
}
.meta-violet {
  color: #5E5CE6;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(94, 92, 230, 0.12); color: #5E5CE6; }
.tone-emerald { background: rgba(52, 199, 89, 0.12); color: #0F9D58; }
.tone-zinc    { background: #E5E5EA; color: #3C3C43; }

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34C759;
  animation: live-pulse 1.8s ease-in-out infinite;
}
@keyframes live-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.55; transform: scale(0.85); }
}

/* ============ Progress mini-bar ============ */
.progress-bar {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.p-cell {
  width: 22rpx;
  height: 8rpx;
  border-radius: 4rpx;
}
.p-done    { background: rgba(52, 199, 89, 0.70); }
.p-active  { background: #5E5CE6; }
.p-pending { background: #D1D1D6; }
.p-more {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

/* ============ Bottom pad ============ */
.bottom-pad {
  height: 80rpx;
}

/* ============ Bottom Nav (跟 page bg 完全一致) ============ */
.navbar {
  flex-shrink: 0;
  display: flex;
  background: #F2F2F7;
  padding: 6rpx 0 0;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  color: #8E8E93;
  transition: color 0.2s ease;
}
.nav-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.nav-on {
  color: #007AFF;
}
.nav-on .nav-emoji {
  opacity: 1;
}

/* ============ 入场动效 ============ */
@keyframes meeting-enter-anim {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.meeting-enter {
  animation: meeting-enter-anim 0.32s cubic-bezier(0.16, 1, 0.3, 1) both;
}
