/* pages/meetings_list/meetings_list.wxss — v27.0-mobile S2 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
.hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.hd-title {
  font-size: 52rpx;          /* H5 text-[26px] */
  font-weight: 600;
  color: #fafafa;
  line-height: 1;
  letter-spacing: -0.5rpx;
}
.hd-segment {
  margin-top: 32rpx;
  display: flex;
  background: rgba(24, 24, 27, 0.6);   /* ink-900/60 */
  border-radius: 24rpx;
  padding: 8rpx;                       /* p-1 */
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 18rpx;
  color: #d4d4d8;                      /* zinc-300 */
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-label {
  font-size: 28rpx;                    /* H5 text-[15px] */
}
.seg-count {
  font-size: 24rpx;                    /* H5 text-[13px] */
  color: #71717a;                      /* zinc-500 */
  font-variant-numeric: tabular-nums;
}
.seg-on {
  background: #3f3f46;                 /* zinc-700, 跟 H5 一致 */
  color: #fafafa;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}
.seg-on .seg-count {
  color: #d4d4d8;                      /* zinc-300 */
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

/* "+ 新建会议" */
.new-btn-wrap {
  padding-top: 16rpx;
  padding-bottom: 12rpx;
}
.new-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(139, 92, 246, 0.08);
  border: 2rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 24rpx;
  color: #c4b5fd;
  font-size: 30rpx;
  font-weight: 500;
  transition: transform 0.15s ease, background 0.15s ease;
}
.new-btn-hover {
  transform: scale(0.985);
  background: rgba(139, 92, 246, 0.15);
}
.new-btn-plus {
  font-size: 38rpx;
  line-height: 1;
}
.new-btn-label {
  font-size: 30rpx;
}

/* ============ Skeleton ============ */
.sk {
  background: #18181b;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk-row { height: 180rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Empty / Error / Centered ============ */
.empty-card {
  margin-top: 24rpx;
  padding: 80rpx 32rpx;
  border: 2rpx dashed #3f3f46;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #71717a;
}
.centered {
  padding: 80rpx 32rpx;
  text-align: center;
}
.centered-title {
  font-size: 32rpx;
  color: #fafafa;
}
.centered-body {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #a1a1aa;
  line-height: 1.6;
}
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 24rpx;
  color: #e4e4e7;
  font-size: 28rpx;
}

/* ============ Meeting card ============ */
.meeting-card {
  background: #18181b;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.meeting-hover {
  transform: scale(0.985);
  background: #1f1f23;
}

.meeting-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.meeting-time {
  flex: 1;
  font-size: 24rpx;
  color: #a1a1aa;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.time-over {
  color: #fcd34d;
}

.meeting-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fafafa;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meeting-meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24rpx 28rpx;
  font-size: 26rpx;
  color: #a1a1aa;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.meta-icon {
  font-size: 26rpx;
}
.meta-num {
  font-variant-numeric: tabular-nums;
}
.meta-label {
  margin-left: 4rpx;
  font-size: 24rpx;
  color: #a1a1aa;
}
.meta-violet {
  color: rgba(196, 181, 253, 0.85);
}

/* ============ Badge ============ */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(139, 92, 246, 0.15); color: #c4b5fd; }
.tone-emerald { background: rgba(16, 185, 129, 0.15); color: #6ee7b7; }
.tone-zinc    { background: #27272a; color: #a1a1aa; }

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34d399;
  animation: live-pulse 1.8s ease-in-out infinite;
}
@keyframes live-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.55; transform: scale(0.85); }
}

/* ============ Progress mini-bar ============ */
.progress-bar {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.p-cell {
  width: 22rpx;
  height: 8rpx;
  border-radius: 4rpx;
}
.p-done    { background: rgba(16, 185, 129, 0.7); }
.p-active  { background: #a78bfa; }
.p-pending { background: #3f3f46; }
.p-more {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: #71717a;
}

/* ============ Bottom pad ============ */
.bottom-pad {
  height: 80rpx;
}

/* ============ Bottom Nav (跟 page bg 完全一致) ============ */
.navbar {
  flex-shrink: 0;
  display: flex;
  background: #0a0a0c;
  padding: 6rpx 0 0;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  color: #71717a;
  transition: color 0.2s ease;
}
.nav-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.nav-on {
  color: #c4b5fd;
}
.nav-on .nav-emoji {
  opacity: 1;
}

/* ============ 入场动效 ============ */
@keyframes meeting-enter-anim {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.meeting-enter {
  animation: meeting-enter-anim 0.32s cubic-bezier(0.16, 1, 0.3, 1) both;
}
