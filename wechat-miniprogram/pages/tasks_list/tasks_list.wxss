/* pages/tasks_list/tasks_list.wxss — v1.4.0 Saga F (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
.hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.hd-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1;
  letter-spacing: -0.5rpx;
}
.hd-segment {
  margin-top: 32rpx;
  display: flex;
  background: #E5E5EA;
  border-radius: 24rpx;
  padding: 8rpx;
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 18rpx;
  color: #3C3C43;
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-label { font-size: 28rpx; }
.seg-count {
  font-size: 24rpx;
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}
.seg-on {
  background: #FFFFFF;
  color: #1C1C1E;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}
.seg-on .seg-count { color: #3C3C43; }

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 0;
}

/* ============ Skeleton ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk-card { height: 380rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Empty / Error / Centered ============ */
.empty-card {
  margin-top: 24rpx;
  padding: 80rpx 32rpx;
  border: 2rpx dashed #D1D1D6;
  border-radius: 24rpx;
  text-align: center;
}
.empty-title {
  font-size: 30rpx;
  color: #1C1C1E;
}
.empty-body {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.6;
}
.centered {
  padding: 80rpx 32rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #1C1C1E; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #8E8E93; line-height: 1.6; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ Pending Task Card (full) ============ */
.task-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  padding: 28rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.task-head-area {
  border-radius: 16rpx;
  padding: 4rpx 0;
  transition: background 0.15s ease;
}
.task-hover {
  background: #F7F7F9;
}

.task-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.task-age {
  font-size: 24rpx;
  color: #8E8E93;
}

.task-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.task-source {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #3C3C43;
}

/* —— AI 智囊 内嵌 —— */
.insights {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(94, 92, 230, 0.06);
  border-left: 4rpx solid rgba(94, 92, 230, 0.45);
  border-radius: 16rpx;
}
.insights-label {
  font-size: 22rpx;
  color: #5E5CE6;
  margin-bottom: 12rpx;
}
.insight-row {
  margin-top: 12rpx;
}
.insight-row:first-of-type {
  margin-top: 0;
}
.insight-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.insight-type-pill {
  flex-shrink: 0;
}
.insight-agent {
  font-size: 22rpx;
  color: #8E8E93;
}
.insight-text {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #1C1C1E;
  line-height: 1.55;
}

/* —— CTA row —— */
.task-cta-row {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}
.cta-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  padding: 0;
  transition: transform 0.15s ease, background 0.15s ease;
}
.cta-btn::after { border: none; }
.cta-primary {
  background: #34C759;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(52, 199, 89, 0.20);
}
.cta-primary-hover {
  transform: scale(0.97);
  box-shadow: 0 1rpx 4rpx rgba(52, 199, 89, 0.15);
}
.cta-secondary {
  background: #FFFFFF;
  color: #1C1C1E;
  border: 2rpx solid #D1D1D6;
}
.cta-secondary-hover {
  transform: scale(0.97);
  background: #F7F7F9;
}
.cta-busy {
  opacity: 0.55;
  box-shadow: none;
}

/* ============ Tracking / Done row (compact) ============ */
.task-row {
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.task-row-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.task-row-title {
  flex: 1;
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-row-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet  { background: rgba(94, 92, 230, 0.12);  color: #5E5CE6; }
.tone-amber   { background: rgba(255, 159, 10, 0.12); color: #8B6914; }
.tone-rose    { background: rgba(255, 59, 48, 0.10);  color: #C9302C; }
.tone-cyan    { background: rgba(48, 176, 199, 0.12); color: #0E7C8E; }
.tone-emerald { background: rgba(52, 199, 89, 0.12);  color: #0F9D58; }
.tone-zinc    { background: #E5E5EA; color: #3C3C43; }

.bottom-pad { height: 80rpx; }

/* ============ Bottom Nav (跟 page bg 完全一致) ============ */
.navbar {
  flex-shrink: 0;
  display: flex;
  background: #F2F2F7;
  padding: 6rpx 0 0;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  color: #8E8E93;
  transition: color 0.2s ease;
}
.nav-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.nav-on { color: #007AFF; }
.nav-on .nav-emoji { opacity: 1; }

/* ============ 入场动效 ============ */
@keyframes task-enter-anim {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.task-enter {
  animation: task-enter-anim 0.32s cubic-bezier(0.16, 1, 0.3, 1) both;
}
