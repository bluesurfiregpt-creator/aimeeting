/* pages/about/about.wxss — v1.4.0 Saga F (iOS 浅色) */

.container {
  padding: 48rpx 40rpx;
  min-height: 100vh;
  background: #F2F2F7;
  color: #1C1C1E;
}
.logo {
  font-size: 56rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-top: 80rpx;
}
.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #8E8E93;
}
.section {
  margin-top: 64rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}
.row:last-child {
  border-bottom: 0;
}
.label {
  font-size: 28rpx;
  color: #8E8E93;
}
.value {
  font-size: 28rpx;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
}
.cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: #007AFF;
  border-radius: 24rpx;
}
.footer {
  margin-top: 96rpx;
  text-align: center;
  font-size: 24rpx;
  color: #C7C7CC;
}
