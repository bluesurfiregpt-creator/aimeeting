.container {
  padding: 48rpx 40rpx;
  min-height: 100vh;
  background: #0a0a0c;
  color: #fafafa;
}
.logo {
  font-size: 56rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-top: 80rpx;
}
.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #a1a1aa;
}
.section {
  margin-top: 64rpx;
  background: #18181b;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid #27272a;
}
.row:last-child {
  border-bottom: 0;
}
.label {
  font-size: 28rpx;
  color: #a1a1aa;
}
.value {
  font-size: 28rpx;
  color: #fafafa;
  font-variant-numeric: tabular-nums;
}
.cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: #6d28d9;
  border-radius: 24rpx;
}
.footer {
  margin-top: 96rpx;
  text-align: center;
  font-size: 24rpx;
  color: #52525b;
}
