<!-- pages/create/create.wxml — N-3 第 1 刀: 骨架 -->
<view class="container">

  <!-- 没 token 时 引导 -->
  <view wx:if="{{needToken}}" class="state-block">
    <view class="state-emoji">📱</view>
    <view class="state-title">请从会议列表 进入</view>
    <view class="state-body">
      正确进入方式: 回小程序首页 → 进会议列表 → 点 "+ 用原生创建" 按钮.
    </view>
    <button class="btn-secondary" bindtap="onBack">返回</button>

    <view class="dev-fallback-divider">— 或开发模式 —</view>
    <textarea class="dev-input" placeholder="粘贴 token" value="{{devTokenInput}}" bindinput="onDevTokenInput" auto-height />
    <input class="dev-input-line" placeholder="(可选) expires_at" value="{{devTokenExpInput}}" bindinput="onDevTokenExpInput" />
    <button class="btn-secondary" bindtap="onDevTokenConfirm">用 token 登录</button>
  </view>

  <!-- 主表单 -->
  <view wx:else class="form-body">

    <!-- ===== 标题 ===== -->
    <view class="section">
      <view class="section-label">会议标题</view>
      <input
        class="input-line"
        placeholder="例: Q1 投诉评估"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="120"
      />
    </view>

    <!-- ===== 会议类型 ===== -->
    <view class="section">
      <view class="section-label">会议类型</view>
      <view class="mode-list">
        <view
          class="mode-row {{mode === 'hybrid' ? 'mode-row-active' : ''}}"
          data-mode="hybrid"
          bindtap="onModeChange"
        >
          <view class="mode-radio">
            <view wx:if="{{mode === 'hybrid'}}" class="mode-radio-inner"></view>
          </view>
          <view class="mode-text">
            <view class="mode-title">真人 + AI 混合</view>
            <view class="mode-body">真人开会, AI 旁观或被召出来发言. 大多场景选这个.</view>
          </view>
        </view>

        <view
          class="mode-row {{mode === 'auto' ? 'mode-row-active' : ''}}"
          data-mode="auto"
          bindtap="onModeChange"
        >
          <view class="mode-radio">
            <view wx:if="{{mode === 'auto'}}" class="mode-radio-inner"></view>
          </view>
          <view class="mode-text">
            <view class="mode-title">全 AI 自主讨论</view>
            <view class="mode-body">真人写议程 + brief, AI 自己跑. 需 ≥ 2 议程项 + ≥ 3 AI 专家.</view>
          </view>
        </view>

        <view
          class="mode-row {{mode === 'human' ? 'mode-row-active' : ''}}"
          data-mode="human"
          bindtap="onModeChange"
        >
          <view class="mode-radio">
            <view wx:if="{{mode === 'human'}}" class="mode-radio-inner"></view>
          </view>
          <view class="mode-text">
            <view class="mode-title">纯 真人 会议</view>
            <view class="mode-body">不召唤 AI. AI 仅做实时转录 + 纪要.</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== brief (description) ===== -->
    <view class="section">
      <view class="section-label">
        会议 brief / 诉求
        <text class="section-hint" wx:if="{{mode === 'auto'}}">· 全 AI 模式 必填</text>
        <text class="section-hint section-hint-mute" wx:else>· 选填</text>
      </view>
      <textarea
        class="textarea {{mode === 'auto' ? 'textarea-highlight' : ''}}"
        placeholder="{{descriptionPlaceholder}}"
        value="{{description}}"
        bindinput="onDescriptionInput"
        maxlength="2000"
        auto-height
      />
      <view class="char-counter">{{description.length}}/2000</view>
      <!-- 第 2 刀: brief ≥ 10 字时 显 AI 拆议程 按钮 -->
      <view wx:if="{{description.length >= 10}}" class="ai-decompose-row">
        <button
          class="btn-ai-decompose"
          bindtap="onAIDecompose"
          disabled="{{decomposing}}"
        >
          <text wx:if="{{decomposing}}">AI 拆议程中…</text>
          <text wx:else>✨ 让 AI 拆议程</text>
        </button>
      </view>
    </view>

    <!-- ===== 议程 ===== -->
    <view class="section">
      <view class="section-header">
        <view class="section-label">议程 ({{agenda.length}})</view>
        <view class="section-action" bindtap="onAddAgenda">+ 加一项</view>
      </view>
      <view class="agenda-list">
        <view wx:for="{{agenda}}" wx:key="id" class="agenda-row">
          <view class="ar-head">
            <view class="ar-idx">{{index + 1}}.</view>
            <input
              class="ar-title"
              placeholder="议题标题"
              value="{{item.title}}"
              data-idx="{{index}}"
              bindinput="onAgendaTitleInput"
              maxlength="100"
            />
            <view
              wx:if="{{agenda.length > 1}}"
              class="ar-remove"
              data-idx="{{index}}"
              bindtap="onRemoveAgenda"
            >×</view>
          </view>
          <view class="ar-bottom">
            <picker
              mode="selector"
              range="{{durationOptions}}"
              range-key="label"
              data-idx="{{index}}"
              bindchange="onPickDuration"
            >
              <view class="ar-duration">
                <text>时长: {{item.durationLabel}}</text>
              </view>
            </picker>
            <!-- note 折叠按钮 / 展开 textarea -->
            <view
              wx:if="{{!item.noteOpen}}"
              class="ar-note-toggle"
              data-idx="{{index}}"
              bindtap="onToggleAgendaNote"
            >+ 方向提示 (可选)</view>
            <view wx:else class="ar-note-block">
              <view class="ar-note-head">
                <text class="ar-note-label">方向提示 (给 AI 看)</text>
                <text
                  class="ar-note-collapse"
                  data-idx="{{index}}"
                  bindtap="onToggleAgendaNote"
                >收起</text>
              </view>
              <textarea
                class="ar-note-textarea"
                placeholder="例: 重点考虑 Q3 时间窗 + 预算 ≤ 30w"
                value="{{item.note}}"
                data-idx="{{index}}"
                bindinput="onAgendaNoteInput"
                maxlength="200"
                auto-height
              />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 邀请 真人 ===== -->
    <view class="section">
      <view class="section-label">
        邀请真人
        <text wx:if="{{selectedUserIds.length > 0}}" class="section-hint section-hint-mute">· 已选 {{selectedUserIds.length}}</text>
      </view>
      <view wx:if="{{membersLoading}}" class="section-loading">加载中…</view>
      <view wx:elif="{{membersErr}}" class="section-hint-line">{{membersErr}}</view>
      <view wx:elif="{{members.length === 0}}" class="section-hint-line">没有可邀请的成员</view>
      <view wx:else class="chip-grid">
        <view
          wx:for="{{members}}"
          wx:key="user_id"
          class="chip {{selectedUserIdMap[item.user_id] ? 'chip-active' : ''}}"
          data-id="{{item.user_id}}"
          bindtap="onToggleUser"
        >
          <view class="chip-label">{{item.name}}</view>
          <view wx:if="{{item.department || item.role}}" class="chip-sub">
            {{item.department || item.role}}
          </view>
          <view wx:if="{{selectedUserIdMap[item.user_id]}}" class="chip-check">✓</view>
        </view>
      </view>
    </view>

    <!-- ===== 邀请 AI 专家 ===== -->
    <view class="section">
      <view class="section-label">
        邀请 AI 专家
        <text wx:if="{{selectedAgentIds.length > 0}}" class="section-hint section-hint-mute">· 已选 {{selectedAgentIds.length}}</text>
        <text wx:if="{{mode === 'auto'}}" class="section-hint">· 全 AI 模式 需 ≥ 3 个 expert</text>
      </view>
      <view wx:if="{{agentsLoading}}" class="section-loading">加载中…</view>
      <view wx:elif="{{agentsErr}}" class="section-hint-line">{{agentsErr}}</view>
      <view wx:elif="{{agents.length === 0}}" class="section-hint-line">工作区没有 AI 专家</view>
      <view wx:else class="chip-grid">
        <view
          wx:for="{{agents}}"
          wx:key="id"
          class="chip chip-agent {{selectedAgentIdMap[item.id] ? 'chip-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onToggleAgent"
        >
          <view class="chip-dot agent-bg-{{item.color || 'violet'}}"></view>
          <view class="chip-label">{{item.nickname || item.name}}</view>
          <view wx:if="{{item.role === 'moderator'}}" class="chip-tag">主持人</view>
          <view wx:if="{{selectedAgentIdMap[item.id]}}" class="chip-check">✓</view>
        </view>
      </view>
    </view>

    <!-- ===== 参考资料 (第 3 刀) ===== -->
    <view class="section">
      <view class="section-label">
        参考资料
        <text wx:if="{{attachments.length > 0}}" class="section-hint section-hint-mute">· {{attachments.length}} 份</text>
        <text wx:else class="section-hint section-hint-mute">· 选填</text>
      </view>

      <!-- 上传操作按钮 -->
      <view class="att-actions">
        <button
          class="btn-att btn-att-wechat"
          bindtap="onChooseFromWeChat"
          disabled="{{uploadingCount > 0}}"
        >💬 微信聊天记录</button>
        <button
          class="btn-att btn-att-album"
          bindtap="onChooseFromAlbum"
          disabled="{{uploadingCount > 0}}"
        >🖼 相册图片</button>
      </view>

      <view wx:if="{{uploadingCount > 0}}" class="att-uploading">
        上传中 · {{uploadingCount}} 个文件…
      </view>

      <view wx:if="{{attachmentsErr}}" class="att-error">{{attachmentsErr}}</view>

      <!-- 附件列表 -->
      <view wx:if="{{attachments.length > 0}}" class="att-list">
        <view wx:for="{{attachments}}" wx:key="id" class="att-item">
          <view class="att-icon">📄</view>
          <view class="att-body">
            <view class="att-name">{{item.filename}}</view>
            <view class="att-meta">
              <text class="att-size">{{item.sizeStr}}</text>
              <text class="att-status-chip att-tone-{{item.statusTone}}">{{item.statusLabel}}</text>
            </view>
          </view>
          <view
            class="att-delete"
            data-id="{{item.id}}"
            data-name="{{item.filename}}"
            bindtap="onDeleteAttachment"
          >×</view>
        </view>
      </view>

      <view class="att-hint">
        支持 PDF / Word / Excel / PPT / 文本 / 图片 (走 OCR). 单文件 ≤ 50MB. AI
        拆议程 + 自主讨论 会读这些资料.
      </view>
    </view>

    <!-- ===== 提示错误 ===== -->
    <view wx:if="{{error}}" class="error-block">{{error}}</view>

    <!-- ===== 提交按钮 ===== -->
    <view class="submit-bar" style="padding-bottom: calc(20rpx + env(safe-area-inset-bottom));">
      <button class="btn-secondary btn-back" bindtap="onBack">取消</button>
      <button
        class="btn-primary btn-create"
        bindtap="onSubmit"
        disabled="{{creating}}"
      >
        <text wx:if="{{creating}}">创建中…</text>
        <text wx:else>创建会议</text>
      </button>
    </view>
  </view>
</view>
