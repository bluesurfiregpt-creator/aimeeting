/* pages/create/create.wxss — N-3 第 1 刀 骨架 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 缺 token 状态 ===== */

.state-block {
  padding: 80rpx 48rpx;
  text-align: center;
}

.state-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 16rpx;
}

.state-body {
  font-size: 26rpx;
  line-height: 1.6;
  color: #71717a;
  background: #18181b;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.dev-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  font-family: ui-monospace, monospace;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.dev-input-line {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.dev-fallback-divider {
  margin: 48rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #52525b;
}

/* ===== 通用按钮 ===== */

.btn-primary {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  border-radius: 16rpx;
  font-weight: 500;
  font-size: 30rpx;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  background: #18181b;
  border: 2rpx solid #3f3f46;
  color: #e4e4e7;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-secondary::after { border: none; }

/* ===== 表单 section ===== */

.form-body {
  padding: 24rpx 32rpx 0;
}

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-label {
  font-size: 26rpx;
  color: #d4d4d8;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #c4b5fd;
  margin-left: 8rpx;
}

.section-hint-mute {
  color: #71717a;
}

.section-action {
  font-size: 26rpx;
  color: #a78bfa;
  font-weight: 500;
}

.section-action:active {
  opacity: 0.7;
}

/* ===== 输入框 / textarea ===== */

.input-line {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
  color: #fafafa;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-line:focus {
  border-color: rgba(139, 92, 246, 0.5);
}

.textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
  color: #fafafa;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  min-height: 180rpx;
}

.textarea-highlight {
  border-color: rgba(139, 92, 246, 0.4);
}

.char-counter {
  text-align: right;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #52525b;
  font-variant-numeric: tabular-nums;
}

/* ===== 会议类型 mode 选择 ===== */

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mode-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
}

.mode-row:active {
  background: #20202a;
}

.mode-row-active {
  border-color: rgba(139, 92, 246, 0.5);
  background: rgba(139, 92, 246, 0.08);
}

.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #52525b;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-row-active .mode-radio {
  border-color: #a78bfa;
}

.mode-radio-inner {
  width: 20rpx;
  height: 20rpx;
  background: #a78bfa;
  border-radius: 50%;
}

.mode-text {
  flex: 1;
  min-width: 0;
}

.mode-title {
  font-size: 30rpx;
  color: #fafafa;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.mode-body {
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.55;
}

/* ===== 议程列表 ===== */

.agenda-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.agenda-row {
  padding: 16rpx 20rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
}

.ar-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.ar-idx {
  font-size: 26rpx;
  color: #71717a;
  font-weight: 500;
  flex-shrink: 0;
  width: 40rpx;
}

.ar-title {
  flex: 1;
  height: 64rpx;
  background: transparent;
  color: #fafafa;
  font-size: 28rpx;
  border: none;
}

.ar-remove {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #71717a;
  border-radius: 50%;
}

.ar-remove:active {
  background: rgba(244, 63, 94, 0.15);
  color: #fda4af;
}

.ar-bottom {
  padding-left: 52rpx;
  margin-top: 4rpx;
}

.ar-duration {
  font-size: 24rpx;
  color: #a1a1aa;
  padding: 6rpx 0;
}

.ar-duration:active {
  color: #c4b5fd;
}

/* ===== 占位 section (留后续刀) ===== */

.section-placeholder {
  padding: 24rpx;
  background: #18181b;
  border: 2rpx dashed #3f3f46;
  border-radius: 16rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #71717a;
  font-style: italic;
}

/* ===== 错误提示 ===== */

.error-block {
  margin: 16rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* ===== 底部提交栏 ===== */

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: rgba(15, 15, 18, 0.96);
  border-top: 1rpx solid #27272a;
  backdrop-filter: blur(8rpx);
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-create {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
}
