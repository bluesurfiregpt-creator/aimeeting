/* pages/create/create.wxss — N-3 第 1 刀 骨架 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 缺 token 状态 ===== */

.state-block {
  padding: 80rpx 48rpx;
  text-align: center;
}

.state-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 16rpx;
}

.state-body {
  font-size: 26rpx;
  line-height: 1.6;
  color: #71717a;
  background: #18181b;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.dev-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  font-family: ui-monospace, monospace;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.dev-input-line {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 16rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.dev-fallback-divider {
  margin: 48rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #52525b;
}

/* ===== 通用按钮 ===== */

.btn-primary {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  border-radius: 16rpx;
  font-weight: 500;
  font-size: 30rpx;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  background: #18181b;
  border: 2rpx solid #3f3f46;
  color: #e4e4e7;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-secondary::after { border: none; }

/* ===== 表单 section ===== */

.form-body {
  padding: 24rpx 32rpx 0;
}

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-label {
  font-size: 26rpx;
  color: #d4d4d8;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #c4b5fd;
  margin-left: 8rpx;
}

.section-hint-mute {
  color: #71717a;
}

.section-action {
  font-size: 26rpx;
  color: #a78bfa;
  font-weight: 500;
}

.section-action:active {
  opacity: 0.7;
}

/* ===== 输入框 / textarea ===== */

.input-line {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
  color: #fafafa;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-line:focus {
  border-color: rgba(139, 92, 246, 0.5);
}

.textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
  color: #fafafa;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  min-height: 180rpx;
}

.textarea-highlight {
  border-color: rgba(139, 92, 246, 0.4);
}

.char-counter {
  text-align: right;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #52525b;
  font-variant-numeric: tabular-nums;
}

/* ===== 会议类型 mode 选择 ===== */

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mode-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
}

.mode-row:active {
  background: #20202a;
}

.mode-row-active {
  border-color: rgba(139, 92, 246, 0.5);
  background: rgba(139, 92, 246, 0.08);
}

.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #52525b;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-row-active .mode-radio {
  border-color: #a78bfa;
}

.mode-radio-inner {
  width: 20rpx;
  height: 20rpx;
  background: #a78bfa;
  border-radius: 50%;
}

.mode-text {
  flex: 1;
  min-width: 0;
}

.mode-title {
  font-size: 30rpx;
  color: #fafafa;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.mode-body {
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.55;
}

/* ===== 议程列表 ===== */

.agenda-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.agenda-row {
  padding: 16rpx 20rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
}

.ar-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.ar-idx {
  font-size: 26rpx;
  color: #71717a;
  font-weight: 500;
  flex-shrink: 0;
  width: 40rpx;
}

.ar-title {
  flex: 1;
  height: 64rpx;
  background: transparent;
  color: #fafafa;
  font-size: 28rpx;
  border: none;
}

.ar-remove {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #71717a;
  border-radius: 50%;
}

.ar-remove:active {
  background: rgba(244, 63, 94, 0.15);
  color: #fda4af;
}

.ar-bottom {
  padding-left: 52rpx;
  margin-top: 4rpx;
}

.ar-duration {
  font-size: 24rpx;
  color: #a1a1aa;
  padding: 6rpx 0;
}

.ar-duration:active {
  color: #c4b5fd;
}

/* ===== 占位 section (留后续刀) ===== */

.section-placeholder {
  padding: 24rpx;
  background: #18181b;
  border: 2rpx dashed #3f3f46;
  border-radius: 16rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #71717a;
  font-style: italic;
}

/* ===== 第 2 刀: AI 拆议程 按钮 ===== */

.ai-decompose-row {
  margin-top: 16rpx;
}

/* v27.2: AI 拆议程 按钮 — 一直显, 改全宽 更醒目 (之前 inline 小药丸 不好找) */
.btn-ai-decompose {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.22), rgba(99, 102, 241, 0.14));
  border: 2rpx solid rgba(139, 92, 246, 0.45);
  color: #c4b5fd;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 20rpx;
  margin: 0;
  box-sizing: border-box;
}

.btn-ai-decompose::after { border: none; }

/* brief 不够 10 字 — 灰置 */
.btn-ai-disabled {
  background: #18181b;
  border-color: #27272a;
  color: #52525b;
}

.btn-ai-decompose[disabled] {
  opacity: 1;  /* 用 .btn-ai-disabled 控制 灰, 不靠 opacity */
}

.ai-decompose-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #71717a;
  line-height: 1.5;
}

/* ===== 第 2 刀: 议程 note 折叠 ===== */

.ar-note-toggle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #71717a;
}

.ar-note-toggle:active {
  color: #a78bfa;
}

.ar-note-block {
  margin-top: 8rpx;
}

.ar-note-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.ar-note-label {
  font-size: 22rpx;
  color: #a1a1aa;
}

.ar-note-collapse {
  font-size: 22rpx;
  color: #71717a;
}

.ar-note-collapse:active {
  color: #fda4af;
}

.ar-note-textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 12rpx 16rpx;
  background: #0f0f12;
  border: 1rpx solid #27272a;
  border-radius: 12rpx;
  color: #e4e4e7;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* ===== 第 2 刀: 邀请 chip ===== */

.section-loading {
  font-size: 24rpx;
  color: #71717a;
  padding: 8rpx 0;
}

.section-hint-line {
  font-size: 22rpx;
  color: #71717a;
  padding: 4rpx 0;
  line-height: 1.5;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.chip:active {
  background: #20202a;
}

.chip-active {
  border-color: rgba(139, 92, 246, 0.5);
  background: rgba(139, 92, 246, 0.15);
}

.chip-label {
  color: #e4e4e7;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip-active .chip-label {
  color: #fafafa;
}

.chip-sub {
  font-size: 22rpx;
  color: #71717a;
}

.chip-check {
  font-size: 22rpx;
  color: #a78bfa;
  font-weight: 600;
}

.chip-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.chip-tag {
  padding: 1rpx 8rpx;
  background: rgba(245, 158, 11, 0.15);
  color: #fcd34d;
  border-radius: 6rpx;
  font-size: 20rpx;
}

/* agent color 圆点 (跟 meeting 页保持一致) */
.agent-bg-violet { background: #8b5cf6; }
.agent-bg-emerald { background: #10b981; }
.agent-bg-amber { background: #f59e0b; }
.agent-bg-sky { background: #0ea5e9; }
.agent-bg-rose { background: #f43f5e; }
.agent-bg-teal { background: #14b8a6; }
.agent-bg-blue { background: #3b82f6; }
.agent-bg-indigo { background: #6366f1; }

/* ===== 第 3 刀: 附件 ===== */

.att-actions {
  display: flex;
  gap: 12rpx;
  margin: 12rpx 0;
}

.btn-att {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  margin: 0;
}

.btn-att::after { border: none; }

.btn-att[disabled] {
  opacity: 0.5;
}

.btn-att-wechat {
  background: rgba(16, 185, 129, 0.15);
  color: #6ee7b7;
}

.btn-att-album {
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
}

.att-uploading {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(139, 92, 246, 0.10);
  color: #c4b5fd;
  font-size: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

.att-error {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.att-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.att-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
}

.att-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 4rpx;
}

.att-body {
  flex: 1;
  min-width: 0;
}

.att-name {
  font-size: 26rpx;
  color: #fafafa;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.att-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
}

.att-size {
  color: #71717a;
  font-variant-numeric: tabular-nums;
}

.att-status-chip {
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.att-tone-ready {
  background: rgba(16, 185, 129, 0.15);
  color: #6ee7b7;
}

.att-tone-extracting,
.att-tone-pending {
  background: rgba(139, 92, 246, 0.15);
  color: #c4b5fd;
}

.att-tone-skipped {
  background: rgba(115, 115, 130, 0.15);
  color: #a1a1aa;
}

.att-tone-failed {
  background: rgba(244, 63, 94, 0.15);
  color: #fda4af;
}

.att-delete {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #71717a;
  border-radius: 50%;
  flex-shrink: 0;
}

.att-delete:active {
  background: rgba(244, 63, 94, 0.15);
  color: #fda4af;
}

.att-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #52525b;
  line-height: 1.55;
}

/* ===== 错误提示 ===== */

.error-block {
  margin: 16rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* ===== 底部提交栏 ===== */

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: rgba(15, 15, 18, 0.96);
  border-top: 1rpx solid #27272a;
  backdrop-filter: blur(8rpx);
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-create {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
}
