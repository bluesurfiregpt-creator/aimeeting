/* pages/create/create.wxss — v1.4.0 Saga F (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  font-family: -apple-system, "SF Pro Text", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 缺 token 状态 ===== */

.state-block {
  padding: 80rpx 48rpx;
  text-align: center;
}

.state-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 16rpx;
}

.state-body {
  font-size: 26rpx;
  line-height: 1.6;
  color: #8E8E93;
  background: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.dev-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 24rpx;
  font-family: ui-monospace, monospace;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.dev-input-line {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.dev-fallback-divider {
  margin: 48rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
}

/* ===== 通用按钮 ===== */

.btn-primary {
  background: #007AFF;
  color: #fff;
  border-radius: 16rpx;
  font-weight: 500;
  font-size: 30rpx;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  color: #1C1C1E;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-secondary::after { border: none; }

/* ===== 表单 section ===== */

.form-body {
  padding: 24rpx 32rpx 0;
}

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-label {
  font-size: 26rpx;
  color: #3C3C43;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #007AFF;
  margin-left: 8rpx;
}

.section-hint-mute {
  color: #8E8E93;
}

.section-action {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

.section-action:active {
  opacity: 0.7;
}

/* ===== 输入框 / textarea ===== */

.input-line {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-line:focus {
  border-color: #007AFF;
}

.textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  min-height: 180rpx;
}

.textarea-highlight {
  border-color: rgba(0, 122, 255, 0.4);
}

.char-counter {
  text-align: right;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #C7C7CC;
  font-variant-numeric: tabular-nums;
}

/* ===== 会议类型 mode 选择 ===== */

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mode-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
}

.mode-row:active {
  background: #F7F7F9;
}

.mode-row-active {
  border-color: #007AFF;
  background: rgba(0, 122, 255, 0.06);
}

.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #C7C7CC;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-row-active .mode-radio {
  border-color: #007AFF;
}

.mode-radio-inner {
  width: 20rpx;
  height: 20rpx;
  background: #007AFF;
  border-radius: 50%;
}

.mode-text {
  flex: 1;
  min-width: 0;
}

.mode-title {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.mode-body {
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.55;
}

/* ===== 议程列表 ===== */

.agenda-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.agenda-row {
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
}

.ar-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.ar-idx {
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 500;
  flex-shrink: 0;
  width: 40rpx;
}

.ar-title {
  flex: 1;
  height: 64rpx;
  background: transparent;
  color: #1C1C1E;
  font-size: 28rpx;
  border: none;
}

.ar-remove {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #8E8E93;
  border-radius: 50%;
}

.ar-remove:active {
  background: rgba(255, 59, 48, 0.10);
  color: #FF3B30;
}

.ar-bottom {
  padding-left: 52rpx;
  margin-top: 4rpx;
}

.ar-duration {
  font-size: 24rpx;
  color: #8E8E93;
  padding: 6rpx 0;
}

.ar-duration:active {
  color: #007AFF;
}

/* ===== 占位 section (留后续刀) ===== */

.section-placeholder {
  padding: 24rpx;
  background: #FFFFFF;
  border: 2rpx dashed #D1D1D6;
  border-radius: 16rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-style: italic;
}

/* ===== 第 2 刀: AI 拆议程 按钮 ===== */

.ai-decompose-row {
  margin-top: 16rpx;
}

.btn-ai-decompose {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 84rpx;
  background: rgba(94, 92, 230, 0.10);
  border: 2rpx solid rgba(94, 92, 230, 0.35);
  color: #5E5CE6;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 20rpx;
  margin: 0;
  box-sizing: border-box;
}

.btn-ai-decompose::after { border: none; }

.btn-ai-disabled {
  background: #F7F7F9;
  border-color: #E5E5EA;
  color: #C7C7CC;
}

.btn-ai-decompose[disabled] {
  opacity: 1;
}

.ai-decompose-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8E8E93;
  line-height: 1.5;
}

/* ===== 第 2 刀: 议程 note 折叠 ===== */

.ar-note-toggle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

.ar-note-toggle:active {
  color: #007AFF;
}

.ar-note-block {
  margin-top: 8rpx;
}

.ar-note-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.ar-note-label {
  font-size: 22rpx;
  color: #8E8E93;
}

.ar-note-collapse {
  font-size: 22rpx;
  color: #8E8E93;
}

.ar-note-collapse:active {
  color: #FF3B30;
}

.ar-note-textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 12rpx 16rpx;
  background: #F7F7F9;
  border: 1rpx solid #E5E5EA;
  border-radius: 12rpx;
  color: #1C1C1E;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* ===== 第 2 刀: 邀请 chip ===== */

.section-loading {
  font-size: 24rpx;
  color: #8E8E93;
  padding: 8rpx 0;
}

.section-hint-line {
  font-size: 22rpx;
  color: #8E8E93;
  padding: 4rpx 0;
  line-height: 1.5;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.chip:active {
  background: #F7F7F9;
}

.chip-active {
  border-color: #007AFF;
  background: rgba(0, 122, 255, 0.08);
}

.chip-label {
  color: #1C1C1E;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip-active .chip-label {
  color: #1C1C1E;
}

.chip-sub {
  font-size: 22rpx;
  color: #8E8E93;
}

.chip-check {
  font-size: 22rpx;
  color: #007AFF;
  font-weight: 600;
}

.chip-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.chip-tag {
  padding: 1rpx 8rpx;
  background: rgba(255, 159, 10, 0.12);
  color: #8B6914;
  border-radius: 6rpx;
  font-size: 20rpx;
}

/* agent color 圆点 — iOS 系统色 */
.agent-bg-violet  { background: #5E5CE6; }
.agent-bg-emerald { background: #34C759; }
.agent-bg-amber   { background: #FF9F0A; }
.agent-bg-sky     { background: #007AFF; }
.agent-bg-rose    { background: #FF375F; }
.agent-bg-teal    { background: #30B0C7; }
.agent-bg-blue    { background: #007AFF; }
.agent-bg-indigo  { background: #5E5CE6; }

/* ===== 第 3 刀: 附件 ===== */

.att-actions {
  display: flex;
  gap: 12rpx;
  margin: 12rpx 0;
}

.btn-att {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  margin: 0;
}

.btn-att::after { border: none; }

.btn-att[disabled] {
  opacity: 0.5;
}

.btn-att-wechat {
  background: rgba(7, 193, 96, 0.10);
  color: #07C160;
}

.btn-att-album {
  background: rgba(0, 122, 255, 0.10);
  color: #007AFF;
}

.att-uploading {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(94, 92, 230, 0.10);
  color: #5E5CE6;
  font-size: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

.att-error {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.att-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.att-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
}

.att-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 4rpx;
}

.att-body {
  flex: 1;
  min-width: 0;
}

.att-name {
  font-size: 26rpx;
  color: #1C1C1E;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.att-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
}

.att-size {
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}

.att-status-chip {
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.att-tone-ready {
  background: rgba(52, 199, 89, 0.12);
  color: #0F9D58;
}

.att-tone-extracting,
.att-tone-pending {
  background: rgba(94, 92, 230, 0.12);
  color: #5E5CE6;
}

.att-tone-skipped {
  background: #E5E5EA;
  color: #3C3C43;
}

.att-tone-failed {
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
}

.att-delete {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #8E8E93;
  border-radius: 50%;
  flex-shrink: 0;
}

.att-delete:active {
  background: rgba(255, 59, 48, 0.10);
  color: #FF3B30;
}

.att-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #C7C7CC;
  line-height: 1.55;
}

/* ===== 错误提示 ===== */

.error-block {
  margin: 16rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* ===== 底部提交栏 ===== */

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: rgba(242, 242, 247, 0.96);
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
  backdrop-filter: blur(8rpx);
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-create {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
}
