/* pages/home/home.wxss — v1.4.0 Saga F (iOS 浅色)
   配色对齐 Mobile MR_COLORS (frontend/src/components/mobile/meeting-room/styles.ts). */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Header (跟 H5 PageHeader 对齐) ============ */
.hd {
  flex-shrink: 0;
  padding: 40rpx 32rpx 24rpx;
}
.hd-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1;
  letter-spacing: -0.5rpx;
}
.hd-segment {
  margin-top: 32rpx;
  display: flex;
  background: #E5E5EA;
  border-radius: 24rpx;
  padding: 8rpx;
  width: 380rpx;
}
.seg-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #3C3C43;
  border-radius: 18rpx;
  transition: background 0.2s ease, color 0.2s ease;
}
.seg-on {
  background: #FFFFFF;
  color: #1C1C1E;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

/* ============ Body (scroll) ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

/* ============ Skeleton ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk-hero { height: 280rpx; }
.sk-row { height: 140rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Section ============ */
.sec {
  margin: 24rpx 0 32rpx;
}
.sec-head {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.sec-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1C1C1E;
}
.sec-count {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #8E8E93;
}
.sec-link {
  margin-left: auto;
  font-size: 24rpx;
  color: #007AFF;
  padding: 8rpx 0 8rpx 24rpx;
}

/* ============ Hero (进行中会议) ============ */
.sec-hero {
  margin-top: 16rpx;
}
.hero-card {
  background: #FFFFFF;
  border: 2rpx solid rgba(94, 92, 230, 0.20);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  transition: transform 0.15s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.hero-hover {
  transform: scale(0.98);
}
.hero-tag {
  font-size: 22rpx;
  color: #5E5CE6;
  letter-spacing: 0.5rpx;
  font-weight: 500;
}
.hero-title {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.3;
}
.hero-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #3C3C43;
}
.hero-meta .dot {
  margin: 0 12rpx;
  color: #C7C7CC;
}
.hero-insight {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #F7F7F9;
  border-radius: 20rpx;
  border-left: 4rpx solid #5E5CE6;
}
.hero-insight-head {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.hero-insight-agent {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #8E8E93;
}
.hero-insight-text {
  font-size: 26rpx;
  color: #1C1C1E;
  line-height: 1.5;
}
.hero-cta {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
  text-align: right;
}

/* 空 hero */
.hero-empty {
  background: #FFFFFF;
  border: 2rpx dashed #D1D1D6;
  border-radius: 32rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}
.hero-empty-emoji {
  font-size: 64rpx;
  line-height: 1;
}
.hero-empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #1C1C1E;
}
.hero-empty-body {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

/* ============ Row card (pending / insight topic) ============ */
.row-card {
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.row-hover {
  transform: scale(0.98);
  background: #F7F7F9;
}
.row-head {
  display: flex;
  align-items: center;
}
.row-title {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
  flex: 1;
  margin-left: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.row-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8E8E93;
}
.row-preview {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #3C3C43;
  line-height: 1.5;
}
.row-cta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #007AFF;
  text-align: right;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tone-violet {
  background: rgba(94, 92, 230, 0.12);
  color: #5E5CE6;
}
.tone-amber {
  background: rgba(255, 159, 10, 0.12);
  color: #8B6914;
}
.tone-rose {
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
}
.tone-cyan {
  background: rgba(48, 176, 199, 0.12);
  color: #0E7C8E;
}
.tone-zinc {
  background: #E5E5EA;
  color: #3C3C43;
}

/* ============ Empty thin (pending 0 / insight 0) ============ */
.empty-thin {
  border: 2rpx dashed #D1D1D6;
  background: rgba(52, 199, 89, 0.05);
  border-color: rgba(52, 199, 89, 0.30);
  color: #0F9D58;
  border-radius: 20rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
}

/* ============ Centered (error / login / empty view) ============ */
.centered {
  padding: 80rpx 32rpx;
  text-align: center;
}
.centered-emoji {
  font-size: 80rpx;
  line-height: 1;
}
.centered-title {
  margin-top: 24rpx;
  font-size: 32rpx;
  color: #1C1C1E;
}
.centered-body {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.6;
}
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

.bottom-pad {
  height: 80rpx;
}

/* ============ Expert view (S1 第 2 刀) ============ */
.expert-count {
  margin: 8rpx 8rpx 16rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

.empty-experts {
  margin: 64rpx 0;
  padding: 64rpx 32rpx;
  background: #FFFFFF;
  border: 2rpx dashed #D1D1D6;
  border-radius: 32rpx;
  text-align: center;
}
.empty-experts-emoji {
  font-size: 80rpx;
  line-height: 1;
}
.empty-experts-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #1C1C1E;
}
.empty-experts-body {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

/* —— 工卡 —— */
.agent-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  transition: transform 0.15s ease, background 0.15s ease;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.agent-hover {
  transform: scale(0.985);
  background: #F7F7F9;
}
.agent-row {
  display: flex;
  align-items: stretch;
}

/* 色条 — iOS 系统色 */
.agent-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.bar-violet  { background: #5E5CE6; }
.bar-emerald { background: #34C759; }
.bar-amber   { background: #FF9F0A; }
.bar-sky     { background: #007AFF; }
.bar-rose    { background: #FF375F; }
.bar-teal    { background: #30B0C7; }
.bar-blue    { background: #007AFF; }
.bar-indigo  { background: #5E5CE6; }
.bar-zinc    { background: #C7C7CC; }

.agent-body {
  flex: 1;
  min-width: 0;
  padding: 28rpx 28rpx 28rpx 24rpx;
}

/* Header */
.agent-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.agent-head-l {
  flex: 1;
  min-width: 0;
}
.agent-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agent-domain {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #3C3C43;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.muted {
  color: #8E8E93;
}
.agent-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8E8E93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agent-head-r {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.agent-active {
  font-size: 22rpx;
  color: #8E8E93;
}
.agent-inactive {
  font-size: 22rpx;
  color: #3C3C43;
  background: #E5E5EA;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

/* Chevron */
.chevron-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #E5E5EA;
  color: #3C3C43;
  font-size: 18rpx;
  transition: transform 0.2s ease, background 0.15s ease;
}
.chevron-btn:active {
  background: #D1D1D6;
  transform: scale(0.92);
}
.chevron-open {
  transform: rotate(180deg);
}

/* —— 展开后 子 section —— */
.sec-block {
  margin-top: 32rpx;
}
.sec-block-border {
  border-top: 2rpx solid #E5E5EA;
  padding-top: 24rpx;
}
.sec-block-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.sec-block-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #3C3C43;
}
.sec-block-count {
  font-size: 24rpx;
  color: #8E8E93;
}
.sec-block-empty {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8E8E93;
}

/* 最近会议 list */
.meeting-list {
  margin-top: 16rpx;
}
.meeting-item {
  margin-bottom: 12rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.meeting-date {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8E8E93;
  font-variant-numeric: tabular-nums;
}
.meeting-title {
  flex: 1;
  font-size: 28rpx;
  color: #3C3C43;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 任务 stat */
.task-line {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}
.task-stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.task-num {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
}
.task-num-done {
  color: #0F9D58;
}
.task-num-overdue {
  color: #FF3B30;
}
.task-label {
  font-size: 26rpx;
  color: #3C3C43;
}
.task-label-overdue {
  color: #C9302C;
}

/* ============ 入场动效 (fade + slide-up + stagger) ============ */
@keyframes agent-enter-anim {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
.agent-enter {
  animation: agent-enter-anim 0.36s cubic-bezier(0.16, 1, 0.3, 1) both;
}

/* ============ Bottom Nav (跟 page bg 完全一致) ============ */
.navbar {
  flex-shrink: 0;
  display: flex;
  background: #F2F2F7;
  padding: 6rpx 0 0;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 10rpx;
  color: #8E8E93;
  transition: color 0.2s ease;
}
.nav-emoji {
  font-size: 40rpx;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}
.nav-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.nav-on {
  color: #007AFF;
}
.nav-on .nav-emoji {
  opacity: 1;
}
