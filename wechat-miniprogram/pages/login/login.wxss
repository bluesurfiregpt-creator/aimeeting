/* pages/login/login.wxss — v1.4.0 Saga F OAuth 登录页 (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 0 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ============ Hero ============ */
.hero {
  margin-top: 160rpx;
  text-align: center;
}
.hero-logo {
  font-size: 120rpx;
  line-height: 1;
}
.hero-title {
  margin-top: 32rpx;
  font-size: 56rpx;
  font-weight: 600;
  color: #1C1C1E;
  letter-spacing: 2rpx;
}
.hero-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8E8E93;
  letter-spacing: 1rpx;
}

/* ============ CTA section (大按钮 + 提示) ============ */
.cta-section {
  margin-top: 200rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* WeChat 绿 — 品牌色, 保留 (MR_COLORS.wechatGreen #07C160) */
.btn-wx-login {
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  color: #fff;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
  border: none;
  padding: 0;
  transition: transform 0.15s ease;
}
.btn-wx-login::after {
  border: none;
}
.btn-wx-hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.15);
}
.btn-disabled {
  opacity: 0.55;
  box-shadow: none;
}
.btn-wx-emoji {
  font-size: 38rpx;
  margin-right: 16rpx;
}
.btn-wx-label {
  font-size: 32rpx;
}

/* 副 CTA: 微信手机号一键登录 */
.btn-phone-login {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 193, 96, 0.08);
  color: #07C160;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid rgba(7, 193, 96, 0.35);
  padding: 0;
  transition: transform 0.15s ease, background 0.15s ease;
}
.btn-phone-login::after {
  border: none;
}
.btn-phone-hover {
  transform: scale(0.97);
  background: rgba(7, 193, 96, 0.16);
}
.btn-phone-emoji {
  font-size: 32rpx;
  margin-right: 14rpx;
}
.btn-phone-label {
  font-size: 28rpx;
}

.hint-line {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #8E8E93;
  text-align: center;
  line-height: 1.6;
}
.link {
  color: #007AFF;
}

.error-banner {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 59, 48, 0.10);
  border: 2rpx solid rgba(255, 59, 48, 0.35);
  color: #C9302C;
  border-radius: 16rpx;
  font-size: 24rpx;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

/* ============ Bind section ============ */
.bind-section {
  margin-top: 120rpx;
  flex: 1;
}
.bind-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.bind-body {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #3C3C43;
  line-height: 1.6;
}

.form {
  margin-top: 40rpx;
}
.field {
  margin-bottom: 28rpx;
}
.field-label {
  font-size: 24rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
}
.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 30rpx;
  box-sizing: border-box;
}
.ph {
  color: #C7C7CC;
}
.field-row {
  position: relative;
}
.eye {
  position: absolute;
  right: 0;
  top: 0;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #8E8E93;
}

.btn-primary {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007AFF;
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 16rpx rgba(0, 122, 255, 0.20);
  border: none;
}
.btn-primary::after {
  border: none;
}
.btn-primary-hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.15);
}

.btn-cancel {
  margin-top: 20rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: transparent;
  color: #8E8E93;
  font-size: 28rpx;
}
.btn-cancel-hover {
  color: #3C3C43;
}

.bind-tip {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #C7C7CC;
  text-align: center;
  line-height: 1.6;
}

/* ============ 底栏 ============ */
.foot {
  padding: 32rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
}
.foot-link {
  color: #8E8E93;
  padding: 0 12rpx;
}
.foot-dot {
  color: #D1D1D6;
}
