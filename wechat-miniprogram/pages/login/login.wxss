/* pages/login/login.wxss — v27.1 OAuth 登录页 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 0 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ============ Hero ============ */
.hero {
  margin-top: 160rpx;
  text-align: center;
}
.hero-logo {
  font-size: 120rpx;
  line-height: 1;
}
.hero-title {
  margin-top: 32rpx;
  font-size: 56rpx;
  font-weight: 600;
  color: #fafafa;
  letter-spacing: 2rpx;
}
.hero-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #71717a;
  letter-spacing: 1rpx;
}

/* ============ CTA section (大按钮 + 提示) ============ */
.cta-section {
  margin-top: 200rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wx-login {
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07c160 0%, #06a050 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.3);
  border: none;
  padding: 0;
  transition: transform 0.15s ease;
}
.btn-wx-login::after {
  border: none;
}
.btn-wx-hover {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}
.btn-disabled {
  opacity: 0.55;
  box-shadow: none;
}
.btn-wx-emoji {
  font-size: 38rpx;
  margin-right: 16rpx;
}
.btn-wx-label {
  font-size: 32rpx;
}

/* v27.2 副 CTA: 微信手机号一键登录 — 比主 CTA 低调, 但仍醒目 */
.btn-phone-login {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 193, 96, 0.08);
  color: #34d399;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid rgba(7, 193, 96, 0.35);
  padding: 0;
  transition: transform 0.15s ease, background 0.15s ease;
}
.btn-phone-login::after {
  border: none;
}
.btn-phone-hover {
  transform: scale(0.97);
  background: rgba(7, 193, 96, 0.18);
}
.btn-phone-emoji {
  font-size: 32rpx;
  margin-right: 14rpx;
}
.btn-phone-label {
  font-size: 28rpx;
}

.hint-line {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #71717a;
  text-align: center;
  line-height: 1.6;
}
.link {
  color: #a78bfa;
}

.error-banner {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(244, 63, 94, 0.12);
  border: 2rpx solid rgba(244, 63, 94, 0.35);
  color: #fda4af;
  border-radius: 16rpx;
  font-size: 24rpx;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

/* ============ Bind section ============ */
.bind-section {
  margin-top: 120rpx;
  flex: 1;
}
.bind-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fafafa;
}
.bind-body {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #a1a1aa;
  line-height: 1.6;
}

.form {
  margin-top: 40rpx;
}
.field {
  margin-bottom: 28rpx;
}
.field-label {
  font-size: 24rpx;
  color: #71717a;
  margin-bottom: 12rpx;
}
.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #18181b;
  border: 2rpx solid #27272a;
  border-radius: 16rpx;
  color: #fafafa;
  font-size: 30rpx;
  box-sizing: border-box;
}
.ph {
  color: #52525b;
}
.field-row {
  position: relative;
}
.eye {
  position: absolute;
  right: 0;
  top: 0;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #71717a;
}

.btn-primary {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.3);
  border: none;
}
.btn-primary::after {
  border: none;
}
.btn-primary-hover {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.2);
}

.btn-cancel {
  margin-top: 20rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: transparent;
  color: #71717a;
  font-size: 28rpx;
}
.btn-cancel-hover {
  color: #a1a1aa;
}

.bind-tip {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #52525b;
  text-align: center;
  line-height: 1.6;
}

/* ============ 底栏 ============ */
.foot {
  padding: 32rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 22rpx;
  color: #52525b;
}
.foot-link {
  color: #71717a;
  padding: 0 12rpx;
}
.foot-dot {
  color: #3f3f46;
}
