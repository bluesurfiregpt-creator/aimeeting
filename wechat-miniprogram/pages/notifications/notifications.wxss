/* pages/notifications/notifications.wxss — v27.2 「通知」原生页 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ 顶部 全部已读 条 ============ */
.topbar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}
.topbar-count {
  font-size: 26rpx;
  color: #a1a1aa;
}
.mark-all {
  padding: 12rpx 28rpx;
  background: rgba(139, 92, 246, 0.12);
  border: 2rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 999rpx;
  color: #c4b5fd;
  font-size: 24rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.mark-all-hover {
  transform: scale(0.96);
  background: rgba(139, 92, 246, 0.2);
}
.mark-all-busy {
  opacity: 0.55;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

/* ============ Skeleton ============ */
.sk {
  background: #18181b;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-child { margin-top: 8rpx; }
.sk-row { height: 130rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Empty / Error ============ */
.empty-card {
  margin-top: 64rpx;
  padding: 72rpx 32rpx;
  border: 2rpx dashed #3f3f46;
  border-radius: 24rpx;
  text-align: center;
}
.empty-emoji { font-size: 64rpx; line-height: 1; }
.empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #e4e4e7;
}
.empty-body {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #71717a;
  line-height: 1.6;
}
.centered {
  padding: 100rpx 32rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #fafafa; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #a1a1aa; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  border-radius: 24rpx;
  color: #e4e4e7;
  font-size: 28rpx;
}

/* ============ 通知卡 ============ */
.notif-card {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  background: #18181b;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 24rpx 8rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.notif-hover {
  transform: scale(0.99);
  background: #1f1f23;
}
.notif-unread {
  background: rgba(139, 92, 246, 0.06);
}

.notif-dot-col {
  width: 24rpx;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  padding-top: 14rpx;
}
.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
.dot-zinc   { background: #71717a; }
.dot-amber  { background: #fbbf24; }
.dot-rose   { background: #f43f5e; }
.dot-violet { background: #8b5cf6; }

.notif-emoji {
  flex-shrink: 0;
  font-size: 36rpx;
  line-height: 1.2;
  padding-top: 2rpx;
}
.notif-body {
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
}
.notif-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}
.notif-kind {
  font-size: 28rpx;
  font-weight: 500;
  color: #fafafa;
}
.notif-when {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #71717a;
}
.notif-title {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #a1a1aa;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.bottom-pad {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ 入场动效 ============ */
@keyframes notif-enter-anim {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.notif-enter {
  animation: notif-enter-anim 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}
