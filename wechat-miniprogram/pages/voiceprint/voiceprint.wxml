<!-- pages/voiceprint/voiceprint.wxml — v27.2 声纹库 (workspace 共享) -->

<view class="page page-fade-in">

  <!-- ============ 自定义导航栏 ============ -->
  <view class="cnav" style="padding-top: {{statusBarHeight}}px;">
    <view class="cnav-inner" style="height: {{navBarHeight}}px;">
      <view class="cnav-back" bindtap="onTapBack" hover-class="cnav-back-hover">
        <text class="cnav-back-arrow">‹</text>
      </view>
      <view class="cnav-title">声纹库</view>
    </view>
  </view>

  <!-- Loading -->
  <block wx:if="{{loading}}">
    <view class="sk sk-row"></view>
    <view class="sk sk-row"></view>
    <view class="sk sk-row"></view>
  </block>

  <!-- Error -->
  <block wx:elif="{{error}}">
    <view class="centered">
      <view class="centered-title">未能加载</view>
      <view class="centered-body">{{error}}</view>
      <button class="btn-ghost" bindtap="onTapRetry">重试</button>
    </view>
  </block>

  <!-- 正常 -->
  <block wx:else>
    <scroll-view scroll-y class="body">

      <!-- 概览 -->
      <view class="summary">
        <view class="summary-num">{{enrolledCount}} / {{total}}</view>
        <view class="summary-text">
          工作区已录 {{enrolledCount}} 人 · 共 {{total}} 人. 会议中系统自动识别已录者发言.
        </view>
      </view>

      <!-- 录新人 (仅 leader+) -->
      <view
        wx:if="{{isWriter}}"
        class="add-new-btn"
        bindtap="onTapAddNew"
        hover-class="add-new-hover"
        hover-stay-time="80"
      >
        <text class="add-new-plus">+</text>
        <text>录入新人声纹</text>
      </view>

      <view wx:if="{{!isWriter}}" class="member-hint">
        声纹录入需 leader / 管理员 权限. 你可查看 谁已录, 录入请联系管理员.
      </view>

      <!-- 用户列表 -->
      <view class="list-label">工作区成员</view>
      <view
        wx:for="{{users}}"
        wx:key="id"
        wx:for-item="u"
        class="user-row"
      >
        <view class="user-meta">
          <view class="user-name">{{u.name}}</view>
          <view class="user-status {{u.has_voiceprint ? 'status-on' : 'status-off'}}">
            {{u.has_voiceprint ? '● 已录声纹' : '○ 未录'}}
          </view>
        </view>
        <view wx:if="{{isWriter}}" class="user-actions">
          <view
            wx:if="{{u.has_voiceprint}}"
            class="row-btn row-btn-ghost"
            data-id="{{u.id}}"
            data-name="{{u.name}}"
            catchtap="onTapDelete"
          >删除</view>
          <view
            class="row-btn row-btn-primary"
            data-id="{{u.id}}"
            data-name="{{u.name}}"
            catchtap="onTapEnroll"
          >{{u.has_voiceprint ? '重录' : '录入'}}</view>
        </view>
      </view>

      <view class="bottom-pad"></view>
    </scroll-view>
  </block>

  <!-- ============ 输姓名 modal (录新人) ============ -->
  <view wx:if="{{nameInputOpen}}" class="mask">
    <view class="dialog fade-scale-in">
      <view class="dialog-title">录入新人声纹</view>
      <view class="dialog-body">先填 TA 的姓名, 系统建一个档案, 然后录 30 秒声音.</view>
      <input
        class="dialog-input"
        type="text"
        value="{{newUserName}}"
        bindinput="onNewNameInput"
        placeholder="如: 张三"
        placeholder-class="ph"
        confirm-type="done"
        bindconfirm="onConfirmNewName"
      />
      <view class="dialog-actions">
        <view class="dialog-btn dialog-btn-ghost" bindtap="onCancelNameInput">取消</view>
        <view class="dialog-btn dialog-btn-primary" bindtap="onConfirmNewName">下一步</view>
      </view>
    </view>
  </view>

  <!-- ============ 录音 modal ============ -->
  <view wx:if="{{recordOpen}}" class="mask">
    <view class="record-sheet fade-scale-in">
      <view class="record-head">
        <view class="record-title">
          {{isNewUser ? '录入' : '重录'}} · {{targetUserName}}
        </view>
        <view class="record-close" bindtap="onCloseRecordModal">✕</view>
      </view>

      <!-- 朗读文 -->
      <view class="script-box">
        <view class="script-label">
          朗读下面这段 (≥ 20 秒)
          <text class="script-switch" bindtap="onNextScript">换一段</text>
        </view>
        <view class="script-text">{{scriptText}}</view>
      </view>

      <!-- 进度 -->
      <view class="rec-progress-wrap">
        <view class="rec-progress-bar">
          <view class="rec-progress-fill" style="width: {{progressPct}}%;"></view>
        </view>
        <view class="rec-seconds">{{secondsStr}} s</view>
      </view>

      <!-- 按钮 -->
      <block wx:if="{{phase === 'idle'}}">
        <view class="rec-btn rec-btn-start" bindtap="onStartRecord">● 开始录音</view>
      </block>
      <block wx:elif="{{phase === 'starting'}}">
        <view class="rec-btn rec-btn-disabled">启动中…</view>
      </block>
      <block wx:elif="{{phase === 'recording'}}">
        <view
          class="rec-btn {{canSubmit ? 'rec-btn-stop' : 'rec-btn-disabled'}}"
          bindtap="onStopRecord"
        >{{canSubmit ? '■ 停止并提交' : '录够 20 秒才能提交'}}</view>
      </block>
      <block wx:elif="{{phase === 'uploading'}}">
        <view class="rec-btn rec-btn-disabled">上传中…</view>
      </block>

      <view class="rec-tip">在安静环境录, 正常语速朗读, 别离麦太远.</view>
    </view>
  </view>

</view>
