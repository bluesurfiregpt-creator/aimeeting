/* pages/voiceprint/voiceprint.wxss — v1.4.0 Saga F 声纹库 (workspace 共享, iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Skeleton ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 16rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-of-type { margin-top: 24rpx; }
.sk-row { height: 130rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Error ============ */
.centered {
  padding: 100rpx 48rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #1C1C1E; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #8E8E93; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 0;
}

/* ============ 概览 ============ */
.summary {
  background: #FFFFFF;
  border: 2rpx solid rgba(94, 92, 230, 0.20);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.summary-num {
  font-size: 56rpx;
  font-weight: 600;
  color: #1C1C1E;
  font-variant-numeric: tabular-nums;
}
.summary-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #3C3C43;
  line-height: 1.6;
}

/* ============ 录新人 按钮 ============ */
.add-new-btn {
  margin-top: 24rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(0, 122, 255, 0.06);
  border: 2rpx solid rgba(0, 122, 255, 0.30);
  border-radius: 24rpx;
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 500;
  transition: transform 0.15s ease, background 0.15s ease;
}
.add-new-hover {
  transform: scale(0.985);
  background: rgba(0, 122, 255, 0.14);
}
.add-new-plus {
  font-size: 40rpx;
  line-height: 1;
}

.member-hint {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.6;
}

/* ============ 用户列表 ============ */
.list-label {
  margin: 32rpx 0 12rpx 4rpx;
  font-size: 24rpx;
  color: #8E8E93;
}
.user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.user-meta {
  flex: 1;
  min-width: 0;
}
.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-status {
  margin-top: 6rpx;
  font-size: 22rpx;
}
.status-on  { color: #0F9D58; }
.status-off { color: #8E8E93; }

.user-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.row-btn {
  padding: 12rpx 24rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.row-btn-primary {
  background: rgba(0, 122, 255, 0.10);
  color: #007AFF;
}
.row-btn-ghost {
  background: #F7F7F9;
  color: #3C3C43;
  border: 2rpx solid #E5E5EA;
}

.bottom-pad {
  height: calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ Mask (modal 底) ============ */
.mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

/* ============ 输姓名 dialog ============ */
.dialog {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
}
.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.dialog-body {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #3C3C43;
  line-height: 1.6;
}
.dialog-input {
  margin-top: 24rpx;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F7F7F9;
  border: 2rpx solid #E5E5EA;
  border-radius: 16rpx;
  color: #1C1C1E;
  font-size: 30rpx;
  box-sizing: border-box;
}
.ph { color: #C7C7CC; }
.dialog-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}
.dialog-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.dialog-btn-ghost {
  background: #F7F7F9;
  color: #1C1C1E;
  border: 2rpx solid #E5E5EA;
}
.dialog-btn-primary {
  background: #007AFF;
  color: #fff;
}

/* ============ 录音 sheet ============ */
.record-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-sizing: border-box;
}
.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.record-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.record-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8E8E93;
  font-size: 32rpx;
}

/* 朗读文 */
.script-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F7F7F9;
  border-radius: 20rpx;
}
.script-label {
  font-size: 22rpx;
  color: #8E8E93;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.script-switch {
  color: #007AFF;
  font-size: 22rpx;
}
.script-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #1C1C1E;
  line-height: 1.7;
}

/* 进度 */
.rec-progress-wrap {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.rec-progress-bar {
  flex: 1;
  height: 14rpx;
  background: #E5E5EA;
  border-radius: 999rpx;
  overflow: hidden;
}
.rec-progress-fill {
  height: 100%;
  background: #007AFF;
  border-radius: 999rpx;
  transition: width 0.2s linear;
}
.rec-seconds {
  font-size: 26rpx;
  color: #3C3C43;
  font-variant-numeric: tabular-nums;
  min-width: 96rpx;
  text-align: right;
}

/* 录音按钮 */
.rec-btn {
  margin-top: 28rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.rec-btn-start {
  background: #007AFF;
  color: #fff;
}
.rec-btn-stop {
  background: #34C759;
  color: #fff;
}
.rec-btn-disabled {
  background: #E5E5EA;
  color: #8E8E93;
}

.rec-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
}
