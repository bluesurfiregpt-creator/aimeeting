/* pages/picker/picker.wxss — v27.0-mobile P19-B */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
}

.container {
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin: 32rpx 0 56rpx;
  text-align: center;
}

.hero-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 16rpx;
}

.hero-body {
  font-size: 28rpx;
  color: #a1a1aa;
  line-height: 1.6;
  padding: 0 32rpx;
}

.error {
  margin: 0 0 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.btn-primary[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.btn-done {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #18181b;
  border: 2rpx solid #3f3f46;
  color: #e4e4e7;
  font-size: 32rpx;
  border-radius: 24rpx;
  text-align: center;
}

.list {
  margin-top: 40rpx;
}

.list-title {
  font-size: 24rpx;
  color: #71717a;
  margin-bottom: 16rpx;
}

.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #18181b;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  color: #fafafa;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.item-meta {
  font-size: 24rpx;
  color: #6ee7b7;
  flex-shrink: 0;
}

.hint {
  margin-top: 56rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}
