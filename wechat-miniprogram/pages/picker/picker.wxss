/* pages/picker/picker.wxss — v1.4.0 Saga F (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
}

.container {
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin: 32rpx 0 56rpx;
  text-align: center;
}

.hero-emoji {
  font-size: 96rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 16rpx;
}

.hero-body {
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.6;
  padding: 0 32rpx;
}

.error {
  margin: 0 0 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 59, 48, 0.10);
  color: #C9302C;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #34C759;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(52, 199, 89, 0.20);
}

.btn-primary[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.btn-done {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  color: #1C1C1E;
  font-size: 32rpx;
  border-radius: 24rpx;
  text-align: center;
}

.list {
  margin-top: 40rpx;
}

.list-title {
  font-size: 24rpx;
  color: #8E8E93;
  margin-bottom: 16rpx;
}

.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  color: #1C1C1E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.item-meta {
  font-size: 24rpx;
  color: #0F9D58;
  flex-shrink: 0;
}

.hint {
  margin-top: 56rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.6;
}
