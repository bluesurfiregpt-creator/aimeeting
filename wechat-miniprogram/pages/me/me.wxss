/* pages/me/me.wxss — v1.4.0 Saga F「我的」原生页 (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
}

.body {
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ Skeleton ============ */
.sk {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 32rpx 24rpx;
  animation: sk-pulse 1.4s ease-in-out infinite;
}
.sk:first-child { margin-top: 32rpx; }
.sk-card { height: 200rpx; }
.sk-row { height: 140rpx; }
@keyframes sk-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============ Error ============ */
.centered {
  padding: 100rpx 48rpx;
  text-align: center;
}
.centered-title { font-size: 32rpx; color: #1C1C1E; }
.centered-body { margin-top: 12rpx; font-size: 26rpx; color: #8E8E93; }
.btn-ghost {
  margin-top: 32rpx;
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  border-radius: 24rpx;
  color: #1C1C1E;
  font-size: 28rpx;
}

/* ============ 档案卡 ============ */
.profile-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.avatar {
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #5E5CE6, #007AFF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
}
.profile-meta {
  flex: 1;
  min-width: 0;
}
.profile-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1C1E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.profile-sub {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.profile-account {
  font-size: 26rpx;
  color: #8E8E93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ 信息卡 ============ */
.info-card {
  margin-top: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 32rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}
.info-row:last-child {
  border-bottom: none;
}
.info-row-hover {
  background: #F7F7F9;
}
.info-label {
  font-size: 28rpx;
  color: #3C3C43;
}
.info-value {
  font-size: 28rpx;
  color: #1C1C1E;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.info-arrow {
  color: #C7C7CC;
}

/* ============ Badge (iOS 浅色 tinted) ============ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.tone-violet  { background: rgba(94, 92, 230, 0.12);  color: #5E5CE6; }
.tone-amber   { background: rgba(255, 159, 10, 0.12); color: #8B6914; }
.tone-sky     { background: rgba(0, 122, 255, 0.10);  color: #007AFF; }
.tone-emerald { background: rgba(52, 199, 89, 0.12);  color: #0F9D58; }
.tone-zinc    { background: #E5E5EA; color: #3C3C43; }

/* ============ 退出登录 ============ */
.logout-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 59, 48, 0.30);
  background: rgba(255, 59, 48, 0.06);
  color: #FF3B30;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 24rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}
.logout-btn-hover {
  transform: scale(0.98);
  background: rgba(255, 59, 48, 0.12);
}

.version {
  margin-top: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #C7C7CC;
}
