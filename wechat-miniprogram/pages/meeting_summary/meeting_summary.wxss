/* pages/meeting_summary/meeting_summary.wxss — v1.4.0 Saga F 会议总结 (iOS 浅色) */

page {
  background: #F2F2F7;
  color: #1C1C1E;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 0;
}

/* ============ 状态横幅 ============ */
.done-banner {
  background: rgba(52, 199, 89, 0.06);
  border: 2rpx solid rgba(52, 199, 89, 0.30);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}
.done-banner-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #0F9D58;
}
.done-banner-body {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3C3C43;
  line-height: 1.6;
}

/* ============ Section ============ */
.sec-title {
  margin: 28rpx 4rpx 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #3C3C43;
}
.sec-title-mute { color: #8E8E93; }
.sec-hint {
  margin: -6rpx 4rpx 12rpx;
  font-size: 22rpx;
  color: #8E8E93;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
}

/* ============ 纪要 ============ */
.summary-pending {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 28rpx 0 8rpx;
  font-size: 26rpx;
  color: #3C3C43;
}
.pending-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #5E5CE6;
  animation: pd 1.4s ease-in-out infinite;
}
@keyframes pd {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.pending-hint {
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
  padding-bottom: 16rpx;
}
.summary-skip {
  font-size: 26rpx;
  color: #3C3C43;
  line-height: 1.6;
}
.summary-fail {
  font-size: 26rpx;
  color: #C9302C;
  line-height: 1.6;
}
.retry-btn {
  margin-top: 16rpx;
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 2rpx solid #D1D1D6;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #1C1C1E;
  background: #FFFFFF;
}

/* ===== markdown 块 ===== */
.md-block {
  margin-bottom: 14rpx;
}
.md-block:last-child { margin-bottom: 0; }
.md-h1 {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
}
.md-h1 .md-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.md-h2 {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
}
.md-h2 .md-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.md-li {
  display: flex;
  gap: 12rpx;
  padding-left: 8rpx;
}
.md-li .md-text {
  flex: 1;
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.6;
}
.md-bullet {
  color: #5E5CE6;
  font-size: 28rpx;
  line-height: 1.6;
}
.md-p .md-text {
  font-size: 28rpx;
  color: #3C3C43;
  line-height: 1.65;
}
.md-h1:first-child, .md-h2:first-child { margin-top: 0; }

/* ============ 待办 action ============ */
.action-content {
  font-size: 30rpx;
  color: #1C1C1E;
  line-height: 1.5;
}
.action-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #3C3C43;
}
.action-evidence {
  margin-top: 12rpx;
  border-left: 4rpx solid #D1D1D6;
  padding-left: 16rpx;
  font-size: 24rpx;
  font-style: italic;
  color: #8E8E93;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.action-cta {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}
.cta-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.cta-primary {
  background: #007AFF;
  color: #fff;
}
.cta-ghost {
  background: #F7F7F9;
  color: #1C1C1E;
  border: 2rpx solid #E5E5EA;
}
.cta-busy { opacity: 0.55; }

.no-action-card {
  border: 2rpx dashed #D1D1D6;
  border-radius: 20rpx;
  padding: 36rpx 0;
  text-align: center;
}
.no-action-title { font-size: 26rpx; color: #3C3C43; }
.no-action-body { margin-top: 6rpx; font-size: 22rpx; color: #C7C7CC; }

/* ============ 已处理 ============ */
.decided-row {
  background: #F7F7F9;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
.decided-done   { color: #0F9D58; }
.decided-cancel { color: #C7C7CC; text-decoration: line-through; }

.bottom-pad { height: 40rpx; }

/* ============ 底部导航 ============ */
.foot-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
}
.foot-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.foot-ghost {
  background: #FFFFFF;
  border: 2rpx solid #D1D1D6;
  color: #1C1C1E;
}
.foot-primary {
  background: #007AFF;
  color: #fff;
}
