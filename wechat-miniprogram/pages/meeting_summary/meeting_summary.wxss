/* pages/meeting_summary/meeting_summary.wxss — v27.2 会议总结 */

page {
  background: #0a0a0c;
  color: #e4e4e7;
  font-size: 28rpx;
  height: 100vh;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* ============ Body ============ */
.body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx 0;
}

/* ============ 状态横幅 ============ */
.done-banner {
  background: rgba(16, 185, 129, 0.06);
  border: 2rpx solid rgba(16, 185, 129, 0.3);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}
.done-banner-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #6ee7b7;
}
.done-banner-body {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.6;
}

/* ============ Section ============ */
.sec-title {
  margin: 28rpx 4rpx 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #d4d4d8;
}
.sec-title-mute { color: #71717a; }
.sec-hint {
  margin: -6rpx 4rpx 12rpx;
  font-size: 22rpx;
  color: #71717a;
}

.card {
  background: #18181b;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 12rpx;
}

/* ============ 纪要 ============ */
.summary-pending {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 28rpx 0 8rpx;
  font-size: 26rpx;
  color: #a1a1aa;
}
.pending-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #a78bfa;
  animation: pd 1.4s ease-in-out infinite;
}
@keyframes pd {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.pending-hint {
  text-align: center;
  font-size: 22rpx;
  color: #52525b;
  padding-bottom: 16rpx;
}
.summary-skip {
  font-size: 26rpx;
  color: #a1a1aa;
  line-height: 1.6;
}
.summary-fail {
  font-size: 26rpx;
  color: #fda4af;
  line-height: 1.6;
}
.retry-btn {
  margin-top: 16rpx;
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 2rpx solid #3f3f46;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #d4d4d8;
}

/* ===== markdown 块 ===== */
.md-block {
  margin-bottom: 14rpx;
}
.md-block:last-child { margin-bottom: 0; }
.md-h1 {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
}
.md-h1 .md-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fafafa;
}
.md-h2 {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
}
.md-h2 .md-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #e4e4e7;
}
.md-li {
  display: flex;
  gap: 12rpx;
  padding-left: 8rpx;
}
.md-li .md-text {
  flex: 1;
  font-size: 28rpx;
  color: #d4d4d8;
  line-height: 1.6;
}
.md-bullet {
  color: #a78bfa;
  font-size: 28rpx;
  line-height: 1.6;
}
.md-p .md-text {
  font-size: 28rpx;
  color: #d4d4d8;
  line-height: 1.65;
}
.md-h1:first-child, .md-h2:first-child { margin-top: 0; }

/* ============ 待办 action ============ */
.action-content {
  font-size: 30rpx;
  color: #fafafa;
  line-height: 1.5;
}
.action-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #a1a1aa;
}
.action-evidence {
  margin-top: 12rpx;
  border-left: 4rpx solid #3f3f46;
  padding-left: 16rpx;
  font-size: 24rpx;
  font-style: italic;
  color: #71717a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.action-cta {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}
.cta-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.cta-primary {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
}
.cta-ghost {
  background: #27272a;
  color: #d4d4d8;
}
.cta-busy { opacity: 0.55; }

.no-action-card {
  border: 2rpx dashed #3f3f46;
  border-radius: 20rpx;
  padding: 36rpx 0;
  text-align: center;
}
.no-action-title { font-size: 26rpx; color: #a1a1aa; }
.no-action-body { margin-top: 6rpx; font-size: 22rpx; color: #52525b; }

/* ============ 已处理 ============ */
.decided-row {
  background: rgba(24, 24, 27, 0.5);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
.decided-done { color: #6ee7b7; }
.decided-cancel { color: #52525b; text-decoration: line-through; }

.bottom-pad { height: 40rpx; }

/* ============ 底部导航 ============ */
.foot-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: #0e0e10;
  border-top: 2rpx solid #1f1f23;
}
.foot-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.foot-ghost {
  background: #18181b;
  border: 2rpx solid #3f3f46;
  color: #d4d4d8;
}
.foot-primary {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  color: #fff;
}
