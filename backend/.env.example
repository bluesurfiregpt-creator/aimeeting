# --- App ---
APP_ENV=dev
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- CORS ---
CORS_ALLOW_ORIGINS=https://aimeeting.zhzjpt.cn,http://localhost:3000

# --- DashScope (Aliyun) — Realtime STT ---
# https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=replace_me
# v25.8-#1: paraformer-realtime-v2 是 2025 升级版,中文 WER 比 v1 降 30%+
DASHSCOPE_STT_MODEL=paraformer-realtime-v2
# v25.8-#3: 自定义词表(可选)— 在 DashScope 控制台创建 vocabulary 含业务术语,
# 填入这里;留空 → 用通用词表
# DASHSCOPE_STT_VOCABULARY_ID=vocab-xxxxxxxxxxxxxx

# --- pyannoteAI — Voiceprint / Diarization / Identification ---
# https://pyannote.ai
PYANNOTE_API_KEY=replace_me
PYANNOTE_BASE_URL=https://api.pyannote.ai

# --- Aliyun OSS — Object Storage for recordings & voiceprints ---
OSS_ACCESS_KEY_ID=replace_me
OSS_ACCESS_KEY_SECRET=replace_me
OSS_BUCKET=replace_me
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=oss-cn-hangzhou

# --- Postgres + pgvector ---
DATABASE_URL=postgresql+asyncpg://aimeeting:aimeeting@localhost:5432/aimeeting

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM / Dify (Phase 1.5) ---
DIFY_API_KEY=replace_me_phase1_5
DIFY_BASE_URL=https://api.dify.ai

# --- Auth (Sprint F) ---
# Generate a strong random key with: openssl rand -hex 32
JWT_SECRET=replace_with_random_32_byte_hex
JWT_TTL_DAYS=14
COOKIE_SECURE=true

# --- v26.4 Platform Admin (跨 workspace 平台超管) ---
# 逗号分隔的邮箱列表 — 只有这些邮箱登录后才能调 /api/super/* 端点 + 看到 /super UI.
# 留空 = 没有超管 (默认安全).示例:
# PLATFORM_ADMIN_EMAILS=bluesurfiregpt@gmail.com,ops@yourcompany.com
#
# ⚠️ 部署 gotcha: 改完此项 后必须 `docker compose up -d --force-recreate backend`
#    而不是 `docker compose restart backend` —— restart 不重读 env_file,
#    导致 改完没生效 (踩过坑).
PLATFORM_ADMIN_EMAILS=

# --- v24.4 #2 Sentry 观测 ---
# DSN 不填 → 完全 no-op,启动正常.填上立即激活.
# 拿 DSN: https://sentry.io → 新建 Project type=Python(FastAPI) →
#         Project Settings → Client Keys (DSN) → 复制
# 验证: curl http://localhost:8000/healthz 返回里 sentry_active: true
# SENTRY_DSN=https://abc123@o4500001.ingest.sentry.io/4500002
# SENTRY_ENVIRONMENT=prod
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_SEND_DEFAULT_PII=false
